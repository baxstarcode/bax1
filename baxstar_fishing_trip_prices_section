    .sublead{
      margin:12px 0 0;
      color:var(--muted);
      max-width:760px;
      font-size:1.05rem;
      line-height:1.65;
    }

    .usp-row{
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
      gap:14px;
      margin-top:24px;
    }

    .usp{
      background:linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015));
