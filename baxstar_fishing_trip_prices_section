      text-transform:uppercase;
      letter-spacing:.04em;
    }

    .table-intro p{
      margin:8px 0 0;
      color:var(--muted);
      line-height:1.5;
      max-width:760px;
    }

    .table-wrap{
      overflow:auto;
      border-radius:20px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(8,9,12,.70);
