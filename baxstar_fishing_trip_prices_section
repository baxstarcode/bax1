      letter-spacing:.01em;
      white-space:normal;
    }

    .table-note{
      padding:14px 4px 0;
      color:#cfd0d6;
      font-size:.95rem;
      line-height:1.5;
    }

    .table-note strong{color:#fff}

    .bottom-row{
      display:grid;
      grid-template-columns:1fr auto;
      gap:18px;
      align-items:center;
      margin-top:26px;
    }

    .bottom-features{
      display:grid;
      grid-template-columns:repeat(3, minmax(0,1fr));
      gap:16px;
      justify-items:center;
    }

    .mini{
      display:flex;
      align-items:flex-start;
      gap:12px;
      width:100%;
      justify-content:center;
      text-align:left;
      padding:6px 0;
    }

    .mini svg{
      width:32px;
      height:32px;
      stroke:var(--red-2);
      flex:0 0 auto;
      margin-top:2px;
    }

    .mini h3{
      margin:0 0 4px;
      font-size:1rem;
      text-transform:uppercase;
      letter-spacing:.05em;
    }

    .mini p{
      margin:0;
      color:var(--muted);
      line-height:1.45;
      font-size:.96rem;
    }

    .cta{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:320px;
      min-height:88px;
      padding:18px 28px;
      border-radius:22px;
      text-decoration:none;
      color:#fff;
      background:
