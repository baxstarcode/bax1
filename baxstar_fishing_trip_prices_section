      border:1px solid rgba(255,255,255,.10);
      box-shadow:
        0 18px 30px rgba(132,9,14,.35),
        inset 0 1px 0 rgba(255,255,255,.18);
      transition:transform .18s ease, box-shadow .18s ease, filter .18s ease;
    }

    .cta:hover,
    .cta:focus-visible{
      transform:translateY(-2px);
      box-shadow:
        0 26px 38px rgba(132,9,14,.40),
        inset 0 1px 0 rgba(255,255,255,.20);
      filter:saturate(1.05);
      outline:none;
    }

    .cta span{
      display:block;
      text-align:center;
    }

    .cta .big{
      font-weight:900;
      font-size:1.35rem;
      text-transform:uppercase;
      letter-spacing:.08em;
      line-height:1;
    }

    .cta .small{
      margin-top:8px;
      font-size:.98rem;
      text-transform:uppercase;
      letter-spacing:.12em;
      opacity:.96;
    }

    .seo-copy{
      margin-top:22px;
      padding-top:20px;
      border-top:1px solid rgba(255,255,255,.08);
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:20px;
    }

    .seo-copy h2{
      margin:0 0 10px;
      font-size:1.2rem;
      text-transform:uppercase;
      letter-spacing:.05em;
    }

    .seo-copy p{
      margin:0;
      color:var(--muted);
      line-height:1.65;
    }

    @media (max-width: 1180px){
      .hero-grid{grid-template-columns:1fr}
      .hero-visual{min-height:360px}
      .bottom-row{grid-template-columns:1fr}
      .cta{justify-self:center}
      .seo-copy{grid-template-columns:1fr}
    }

    @media (max-width: 860px){
      .page{width:min(var(--max), calc(100% - 20px)); margin:12px auto 20px}
      .hero{padding:22px 18px 20px; border-radius:24px}
      .usp-row,
      .bottom-features{grid-template-columns:1fr}
      .table-intro{align-items:flex-start}
      .cta{width:100%; min-width:0}
    }

    @media (prefers-reduced-motion: reduce){
      *{scroll-behavior:auto}
      .cta{transition:none}
    }
  </style>
