<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Baxstar Fishing — Hero V1: Brand Aligned</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bax-black: #0a0a0a;
    --bax-charcoal: #1a1a1a;
    --bax-red: #c1272d;
    --bax-red-glow: #e63946;
    --bax-white: #f5f5f0;
    --bax-cream: #e8e4dc;
    --bax-gold: #d4a843;
    --bax-slate: #8a8a8a;
    --font-display: 'Oswald', sans-serif;
    --font-body: 'Barlow', sans-serif;
  }

  body {
    font-family: var(--font-body);
    background: var(--bax-black);
    color: var(--bax-white);
    overflow-x: hidden;
  }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(10,10,10,0.15) 0%,
        rgba(10,10,10,0.0) 30%,
        rgba(10,10,10,0.4) 60%,
        rgba(10,10,10,0.92) 85%,
        rgba(10,10,10,1) 100%),
      url('https://images.unsplash.com/photo-1504309092620-4d0ec726efa4?w=1920&q=80') center/cover no-repeat;
    transform: scale(1.05);
    animation: heroZoom 20s ease-in-out infinite alternate;
  }

  @keyframes heroZoom {
    0% { transform: scale(1.05); }
    100% { transform: scale(1.12); }
  }

  /* Red accent line at top */
  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, transparent, var(--bax-red), var(--bax-red-glow), var(--bax-red), transparent);
    z-index: 10;
  }

  /* ─── NAV BAR ─── */
  .topbar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    padding: 24px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    animation: fadeDown 1s ease 0.3s both;
  }

  .topbar__logo {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--bax-white);
  }

  .topbar__logo span {
    color: var(--bax-red);
  }

  .topbar__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    background: var(--bax-red);
    color: white;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .topbar__cta:hover {
    background: var(--bax-red-glow);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(193, 39, 45, 0.4);
  }

  /* ─── HERO CONTENT ─── */
  .hero__content {
    position: relative;
    z-index: 5;
    padding: 0 48px 80px;
    max-width: 900px;
  }

  .hero__tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--bax-red-glow);
    margin-bottom: 20px;
    animation: fadeUp 0.8s ease 0.6s both;
  }

  .hero__tag::before {
    content: '';
    width: 40px;
    height: 2px;
    background: var(--bax-red);
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(42px, 7vw, 82px);
    font-weight: 700;
    line-height: 1.0;
    text-transform: uppercase;
    letter-spacing: -1px;
    color: var(--bax-white);
    margin-bottom: 24px;
    animation: fadeUp 0.8s ease 0.8s both;
  }

  .hero__headline em {
    font-style: normal;
    color: var(--bax-red);
    display: block;
  }

  .hero__sub {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--bax-cream);
    max-width: 560px;
    margin-bottom: 40px;
    animation: fadeUp 0.8s ease 1.0s both;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    animation: fadeUp 0.8s ease 1.2s both;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 18px 40px;
    background: var(--bax-red);
    color: white;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.35s ease;
    position: relative;
    overflow: hidden;
  }

  .btn-primary::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: left 0.5s ease;
  }

  .btn-primary:hover::after { left: 100%; }
  .btn-primary:hover {
    background: var(--bax-red-glow);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(193, 39, 45, 0.5);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 18px 32px;
    background: transparent;
    color: var(--bax-white);
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(245,245,240,0.25);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    border-color: var(--bax-white);
    background: rgba(245,245,240,0.05);
  }

  /* ─── TRUST STRIP ─── */
  .trust-strip {
    position: relative;
    z-index: 5;
    background: var(--bax-charcoal);
    border-top: 1px solid rgba(245,245,240,0.08);
    padding: 28px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
    animation: fadeUp 0.8s ease 1.4s both;
  }

  .trust-strip__reviews {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .trust-strip__stars {
    display: flex;
    gap: 3px;
    color: var(--bax-gold);
    font-size: 18px;
  }

  .trust-strip__rating {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    color: var(--bax-white);
  }

  .trust-strip__count {
    font-size: 13px;
    color: var(--bax-slate);
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  .trust-strip__badges {
    display: flex;
    align-items: center;
    gap: 36px;
  }

  .trust-badge {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bax-slate);
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .trust-badge__dot {
    width: 6px;
    height: 6px;
    background: var(--bax-red);
    border-radius: 50%;
  }

  .trust-strip__experience {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .experience-stat {
    text-align: center;
  }

  .experience-stat__number {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--bax-white);
    line-height: 1;
  }

  .experience-stat__label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bax-slate);
    margin-top: 4px;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(245,245,240,0.1);
  }

  /* ─── AVAILABILITY PULSE ─── */
  .availability-pulse {
    position: absolute;
    top: 100px;
    right: 48px;
    z-index: 15;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 22px;
    background: rgba(10,10,10,0.75);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(245,245,240,0.08);
    animation: fadeDown 1s ease 1.6s both;
  }

  .pulse-dot {
    width: 10px;
    height: 10px;
    background: #22c55e;
    border-radius: 50%;
    position: relative;
  }

  .pulse-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.3);
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.8); opacity: 0; }
  }

  .availability-text {
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--bax-cream);
  }

  .availability-text strong {
    color: #22c55e;
    font-weight: 600;
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .topbar { padding: 16px 24px; }
    .topbar__logo { font-size: 22px; }
    .hero__content { padding: 0 24px 48px; }
    .hero__sub { font-size: 16px; }
    .trust-strip { padding: 20px 24px; flex-direction: column; align-items: flex-start; }
    .trust-strip__badges { flex-wrap: wrap; gap: 20px; }
    .availability-pulse { top: 80px; right: 24px; }
    .hero__actions { flex-direction: column; align-items: flex-start; }
    .btn-primary, .btn-secondary { width: 100%; justify-content: center; }
  }
</style>
</head>
<body>

<section class="hero">
  <div class="hero__bg"></div>

  <!-- Nav -->
  <div class="topbar">
    <div class="topbar__logo">BAX<span>STAR</span></div>
    <a href="#book" class="topbar__cta">Book Your Trip →</a>
  </div>

  <!-- Availability Badge -->
  <div class="availability-pulse">
    <div class="pulse-dot"></div>
    <div class="availability-text"><strong>Open Water Season</strong> — Dates Filling Fast</div>
  </div>

  <!-- Content -->
  <div class="hero__content">
    <div class="hero__tag">Detroit Lakes, Minnesota</div>
    <h1 class="hero__headline">
      Private. Guided.
      <em>Unforgettable.</em>
    </h1>
    <p class="hero__sub">
      30+ years of precision on these waters. Every trip is private, every detail intentional — from the technique to the tackle. This isn't a charter. It's your day on the lake.
    </p>
    <div class="hero__actions">
      <a href="https://fareharbor.com/embeds/book/baxstarfishing/items/309836/calendar/" class="btn-primary">
        Check Availability
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="#services" class="btn-secondary">Explore Services</a>
    </div>
  </div>

  <!-- Trust Strip -->
  <div class="trust-strip">
    <div class="trust-strip__reviews">
      <div class="trust-strip__rating">4.9</div>
      <div>
        <div class="trust-strip__stars">★★★★★</div>
        <div class="trust-strip__count">From 100+ Google Reviews</div>
      </div>
    </div>

    <div class="trust-strip__badges">
      <div class="trust-badge"><span class="trust-badge__dot"></span>Forbes Featured</div>
      <div class="trust-badge"><span class="trust-badge__dot"></span>5x Master Angler</div>
      <div class="trust-badge"><span class="trust-badge__dot"></span>KVLY · WDAY · KFGO</div>
    </div>

    <div class="trust-strip__experience">
      <div class="experience-stat">
        <div class="experience-stat__number">30+</div>
        <div class="experience-stat__label">Years</div>
      </div>
      <div class="stat-divider"></div>
      <div class="experience-stat">
        <div class="experience-stat__number">100+</div>
        <div class="experience-stat__label">Lakes</div>
      </div>
      <div class="stat-divider"></div>
      <div class="experience-stat">
        <div class="experience-stat__number">5x</div>
        <div class="experience-stat__label">Awards</div>
      </div>
    </div>
  </div>
</section>

</body>
</html>
