<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Baxstar Fishing — Hero V3: Cinematic Immersive</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Libre+Franklin:wght@200;300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --deep: #050b14;
    --ink: #0d1520;
    --steel: #1c2a3a;
    --mist: #c8d6e5;
    --frost: #eef2f7;
    --white: #ffffff;
    --ember: #e85d3a;
    --ember-glow: #ff7a55;
    --teal: #2d9e8f;
    --teal-soft: rgba(45, 158, 143, 0.15);
    --gold: #d4a843;
    --font-display: 'Bebas Neue', sans-serif;
    --font-body: 'Libre Franklin', sans-serif;
  }

  body {
    font-family: var(--font-body);
    background: var(--deep);
    color: var(--frost);
    overflow-x: hidden;
  }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ─── BACKGROUND LAYERS ─── */
  .hero__bg-base {
    position: absolute;
    inset: 0;
    background:
      url('https://images.unsplash.com/photo-1500463959177-e0869687df26?w=1920&q=80') center 30%/cover no-repeat;
    filter: brightness(0.55) saturate(1.2);
    animation: bgPan 30s ease-in-out infinite alternate;
  }

  @keyframes bgPan {
    0% { transform: scale(1.0) translate(0, 0); }
    100% { transform: scale(1.1) translate(-20px, -10px); }
  }

  .hero__bg-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(45, 158, 143, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(232, 93, 58, 0.05) 0%, transparent 50%),
      linear-gradient(180deg,
        rgba(5,11,20,0.5) 0%,
        rgba(5,11,20,0.1) 25%,
        rgba(5,11,20,0.15) 50%,
        rgba(5,11,20,0.7) 75%,
        rgba(5,11,20,1) 100%);
  }

  /* Grain overlay */
  .hero__grain {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* ─── NAV ─── */
  .nav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 30;
    padding: 28px 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    animation: fadeDown 0.8s ease 0.3s both;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-size: 36px;
    letter-spacing: 6px;
    color: var(--white);
  }

  .nav__right {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav__link {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--mist);
    text-decoration: none;
    transition: color 0.3s;
    opacity: 0.7;
  }

  .nav__link:hover { opacity: 1; color: var(--white); }

  .nav__cta {
    padding: 12px 28px;
    background: var(--ember);
    color: var(--white);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s;
  }

  .nav__cta:hover {
    background: var(--ember-glow);
    box-shadow: 0 4px 24px rgba(232, 93, 58, 0.4);
  }

  /* ─── MAIN CONTENT AREA ─── */
  .hero__main {
    position: relative;
    z-index: 10;
    flex: 1;
    display: flex;
    align-items: flex-end;
    padding: 0 56px 0;
  }

  .hero__center {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 60px;
    align-items: end;
    padding-bottom: 40px;
  }

  /* ─── LEFT HEADLINE BLOCK ─── */
  .headline-block {
    max-width: 780px;
  }

  .headline-block__location {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 20px;
    animation: fadeUp 0.7s ease 0.6s both;
  }

  .headline-block__location::before {
    content: '';
    display: block;
    width: 20px;
    height: 20px;
    border: 2px solid var(--teal);
    border-radius: 50%;
    position: relative;
  }

  .headline-block__location::after {
    content: '';
    position: absolute;
    left: 18px;
    top: 50%;
    width: 6px;
    height: 6px;
    background: var(--teal);
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 120px);
    line-height: 0.92;
    letter-spacing: 3px;
    color: var(--white);
    margin-bottom: 28px;
    animation: fadeUp 0.8s ease 0.8s both;
  }

  .hero__title span {
    display: block;
  }

  .hero__title .title-accent {
    -webkit-text-stroke: 1.5px var(--mist);
    color: transparent;
    opacity: 0.5;
  }

  .hero__title .title-ember {
    color: var(--ember);
    font-size: 0.6em;
    letter-spacing: 6px;
  }

  .hero__body {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--mist);
    max-width: 480px;
    margin-bottom: 36px;
    animation: fadeUp 0.8s ease 1.0s both;
  }

  .hero__cta-row {
    display: flex;
    align-items: center;
    gap: 20px;
    animation: fadeUp 0.8s ease 1.2s both;
  }

  .cta-book {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 20px 44px;
    background: var(--ember);
    color: var(--white);
    font-family: var(--font-display);
    font-size: 20px;
    letter-spacing: 3px;
    text-decoration: none;
    transition: all 0.35s;
    position: relative;
    overflow: hidden;
  }

  .cta-book::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s;
  }

  .cta-book:hover::before { transform: translateX(100%); }

  .cta-book:hover {
    background: var(--ember-glow);
    transform: translateY(-2px);
    box-shadow: 0 8px 40px rgba(232, 93, 58, 0.45);
  }

  .cta-secondary {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--mist);
    text-decoration: none;
    border-bottom: 1px solid rgba(200,214,229,0.3);
    padding-bottom: 4px;
    transition: all 0.3s;
  }

  .cta-secondary:hover {
    color: var(--white);
    border-color: var(--white);
  }

  /* ─── RIGHT SIDE — QUICK STATS COLUMN ─── */
  .stats-column {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 200px;
    border-left: 1px solid rgba(200,214,229,0.08);
    padding-left: 40px;
    animation: fadeUp 0.8s ease 1.4s both;
  }

  .stat-item {
    padding: 24px 0;
    border-bottom: 1px solid rgba(200,214,229,0.06);
  }

  .stat-item:last-child { border-bottom: none; }

  .stat-item__value {
    font-family: var(--font-display);
    font-size: 42px;
    letter-spacing: 2px;
    color: var(--white);
    line-height: 1;
  }

  .stat-item__value .unit {
    font-size: 20px;
    color: var(--ember);
  }

  .stat-item__label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--mist);
    opacity: 0.6;
    margin-top: 6px;
  }

  /* ─── BOTTOM BAR ─── */
  .hero__bottom {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(200,214,229,0.06);
    animation: fadeUp 0.8s ease 1.6s both;
  }

  .bottom-cell {
    padding: 28px 56px;
    display: flex;
    align-items: center;
    gap: 16px;
    border-right: 1px solid rgba(200,214,229,0.06);
    transition: background 0.3s;
    cursor: default;
  }

  .bottom-cell:last-child { border-right: none; }

  .bottom-cell:hover {
    background: rgba(200,214,229,0.02);
  }

  .bottom-cell__icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(200,214,229,0.12);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .bottom-cell__icon svg {
    width: 16px;
    height: 16px;
    stroke: var(--teal);
    fill: none;
    stroke-width: 1.5;
  }

  .bottom-cell__text {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1px;
    color: var(--mist);
    line-height: 1.5;
  }

  .bottom-cell__text strong {
    display: block;
    color: var(--white);
    font-weight: 600;
    margin-bottom: 2px;
  }

  /* ─── FLOATING SOCIAL PROOF ─── */
  .social-proof-float {
    position: absolute;
    top: 140px;
    right: 56px;
    z-index: 15;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 24px;
    background: rgba(5,11,20,0.7);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(200,214,229,0.06);
    animation: fadeIn 1s ease 2.0s both;
  }

  .social-proof-float__stars {
    color: var(--gold);
    font-size: 16px;
    letter-spacing: 2px;
  }

  .social-proof-float__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .social-proof-float__rating {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--white);
    letter-spacing: 1px;
  }

  .social-proof-float__sub {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--mist);
    opacity: 0.6;
  }

  .social-proof-float__divider {
    width: 1px;
    height: 36px;
    background: rgba(200,214,229,0.1);
  }

  .social-proof-float__badge {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--ember);
  }

  /* ─── SCROLL INDICATOR ─── */
  .scroll-hint {
    position: absolute;
    bottom: 120px;
    left: 56px;
    z-index: 15;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: fadeIn 1s ease 2.2s both;
  }

  .scroll-hint__text {
    writing-mode: vertical-rl;
    font-size: 9px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--mist);
    opacity: 0.4;
  }

  .scroll-hint__line {
    width: 1px;
    height: 50px;
    background: linear-gradient(180deg, var(--mist), transparent);
    opacity: 0.3;
    animation: scrollPulse 2s ease infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; height: 50px; }
    50% { opacity: 0.6; height: 65px; }
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .hero__center {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .stats-column {
      flex-direction: row;
      border-left: none;
      border-top: 1px solid rgba(200,214,229,0.08);
      padding-left: 0;
      padding-top: 24px;
    }
    .stat-item {
      border-bottom: none;
      border-right: 1px solid rgba(200,214,229,0.06);
      padding: 0 24px 0 0;
    }
    .stat-item:last-child { border-right: none; }
  }

  @media (max-width: 768px) {
    .nav { padding: 20px 24px; }
    .nav__link { display: none; }
    .nav__logo { font-size: 28px; letter-spacing: 4px; }
    .hero__main { padding: 0 24px 0; }
    .hero__bottom {
      grid-template-columns: 1fr 1fr;
    }
    .bottom-cell { padding: 20px 24px; }
    .social-proof-float { right: 24px; top: 100px; }
    .scroll-hint { display: none; }
    .hero__cta-row { flex-direction: column; align-items: flex-start; }
    .cta-book { width: 100%; justify-content: center; }
    .stats-column { flex-wrap: wrap; }
  }

  @media (max-width: 480px) {
    .hero__bottom { grid-template-columns: 1fr; }
    .social-proof-float { display: none; }
  }
</style>
</head>
<body>

<section class="hero">
  <div class="hero__bg-base"></div>
  <div class="hero__bg-overlay"></div>
  <div class="hero__grain"></div>

  <!-- Nav -->
  <nav class="nav">
    <div class="nav__logo">BAXSTAR</div>
    <div class="nav__right">
      <a href="#" class="nav__link">Guided Trips</a>
      <a href="#" class="nav__link">Ice Fishing</a>
      <a href="#" class="nav__link">Pontoons</a>
      <a href="#" class="nav__link">About</a>
      <a href="#" class="nav__cta">Book Now</a>
    </div>
  </nav>

  <!-- Social Proof Float -->
  <div class="social-proof-float">
    <div class="social-proof-float__info">
      <div class="social-proof-float__rating">4.9</div>
      <div class="social-proof-float__sub">100+ Reviews</div>
    </div>
    <div class="social-proof-float__stars">★★★★★</div>
    <div class="social-proof-float__divider"></div>
    <div class="social-proof-float__badge">Forbes<br>Featured</div>
  </div>

  <!-- Scroll Indicator -->
  <div class="scroll-hint">
    <div class="scroll-hint__text">Scroll</div>
    <div class="scroll-hint__line"></div>
  </div>

  <!-- Main Content -->
  <div class="hero__main">
    <div class="hero__center">
      <!-- Left -->
      <div class="headline-block">
        <div class="headline-block__location">Detroit Lakes, Minnesota</div>

        <h1 class="hero__title">
          <span class="title-accent">YOUR WATER.</span>
          <span>YOUR GUIDE.</span>
          <span class="title-ember">YOUR DAY.</span>
        </h1>

        <p class="hero__body">
          Private, precision-guided fishing on Minnesota's finest lakes. 30+ years of local mastery, premium equipment, and an experience built around you — not a group.
        </p>

        <div class="hero__cta-row">
          <a href="https://fareharbor.com/embeds/book/baxstarfishing/items/309836/calendar/" class="cta-book">
            RESERVE YOUR TRIP
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#" class="cta-secondary">View This Week's Report</a>
        </div>
      </div>

      <!-- Right Stats -->
      <div class="stats-column">
        <div class="stat-item">
          <div class="stat-item__value">30<span class="unit">+</span></div>
          <div class="stat-item__label">Years Experience</div>
        </div>
        <div class="stat-item">
          <div class="stat-item__value">5<span class="unit">x</span></div>
          <div class="stat-item__label">Master Angler</div>
        </div>
        <div class="stat-item">
          <div class="stat-item__value">100<span class="unit">%</span></div>
          <div class="stat-item__label">Private Trips</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Feature Bar -->
  <div class="hero__bottom">
    <div class="bottom-cell">
      <div class="bottom-cell__icon">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      </div>
      <div class="bottom-cell__text">
        <strong>Half & Full Day</strong>
        Flexible trip lengths
      </div>
    </div>

    <div class="bottom-cell">
      <div class="bottom-cell__icon">
        <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      </div>
      <div class="bottom-cell__text">
        <strong>Premium Equipment</strong>
        Vexus DVX20S · 300HP Mercury
      </div>
    </div>

    <div class="bottom-cell">
      <div class="bottom-cell__icon">
        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div class="bottom-cell__text">
        <strong>Always Private</strong>
        Never shared — your group only
      </div>
    </div>

    <div class="bottom-cell">
      <div class="bottom-cell__icon">
        <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      </div>
      <div class="bottom-cell__text">
        <strong>100+ Area Lakes</strong>
        We go where they're biting
      </div>
    </div>
  </div>
</section>

</body>
</html>
