  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --black:      #08080a;
      --red:        #c1272d;
      --red-bright: #e63946;
      --cream:      #f0ece4;
      --white:      #ffffff;
      --gray-light: #d4d0c9;   /* lightened ~10% from original #c8c4bc */
      --gray-mid:   #8f8f9a;   /* lightened ~10% from original #7a7a88 */
      --table-bg:   rgba(10, 8, 8, 0.94);
      --row-alt:    rgba(255,255,255,0.035);
      --divider:    rgba(255,255,255,0.08);
    }

    body {
      background: var(--black);
      font-family: 'Barlow', sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    .sr-only {
      position: absolute; width: 1px; height: 1px;
      padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }

    /* ── SECTION SHELL ── */
    .pricing-section {
      position: relative;
      width: 100%;
      min-height: 520px;
      background: var(--black);
      overflow: hidden;
    }

    /*
      BACKGROUND — cinematic dark-red gradient.
      To use your real photo, replace the gradient lines with:
        background-image: url('YOUR_WIX_HOSTED_URL');
        background-size: cover; background-position: center right;
      Keep the first gradient layer for left-side readability.
    */
    .pricing-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      background:
        linear-gradient(to right,
          rgba(8,8,10,1)    0%,
          rgba(8,8,10,0.96) 38%,
          rgba(8,8,10,0.60) 58%,
          rgba(8,8,10,0.15) 75%,
          rgba(8,8,10,0)    100%
        ),
        radial-gradient(ellipse at 90% 40%,
          #7a1808 0%, #4a0d05 28%, #1f0604 58%, #08080a 80%
        );
    }

    .pricing-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0.04;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size: 200px 200px;
    }

    .pricing-content {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 52px 48px 44px;
    }

    /* ── HEADER ── */
    .pricing-header {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 48px;
      align-items: start;
      margin-bottom: 30px;
    }

    .pricing-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.26em;
      color: var(--red-bright);
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .pricing-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(56px, 7.5vw, 92px);
      line-height: 0.9;
      color: var(--white);
      letter-spacing: 0.01em;
      margin-bottom: 18px;
    }

    .pricing-headline span { color: var(--red); display: block; }

    .pricing-subhead {
      font-size: 16px;
      font-weight: 400;
      color: var(--gray-light);
      line-height: 1.65;
      max-width: 340px;
    }

    /* ── Feature badges ── */
    .pricing-badges {
      display: flex;
      align-items: flex-start;
      padding-top: 6px;
    }

    .badge {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 26px;
      border-right: 1px solid rgba(255,255,255,0.11);
    }

    .badge:last-child { border-right: none; padding-right: 0; }
    .badge:first-child { padding-left: 0; }

    .badge-icon {
      width: 46px; height: 46px;
      border: 1.5px solid var(--red);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 10px;
      color: var(--red);
    }

    .badge-icon svg { width: 19px; height: 19px; }

    .badge-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--white);
      text-transform: uppercase;
      margin-bottom: 5px;
    }

    .badge-desc {
      font-size: 16px;
      font-weight: 400;
      color: var(--gray-mid);
      line-height: 1.45;
    }

    /* ── PRICING TABLE ── */
    .table-wrapper {
      width: 100%;
      overflow-x: auto;
      border-radius: 2px;
      border: 1px solid rgba(193,39,45,0.22);
      margin-bottom: 10px;
      -webkit-overflow-scrolling: touch;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 560px;
      background: var(--table-bg);
    }

    thead tr { background: var(--red); }

    thead th {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--white);
      padding: 14px 18px;
      text-align: center;
      white-space: nowrap;
    }

    thead th:first-child,
    thead th:nth-child(2) { text-align: left; }

    tbody tr {
      border-bottom: 1px solid var(--divider);
      transition: background 0.15s ease;
    }

    tbody tr:nth-child(even) { background: var(--row-alt); }
    tbody tr:hover { background: rgba(193,39,45,0.07); }

    tbody td {
      font-size: 14.5px;        /* +10% from 13.5px */
      font-weight: 400;
      color: var(--cream);
      padding: 13px 18px;
      text-align: center;
    }

    tbody td:first-child {
      text-align: left;
      font-weight: 500;
      color: var(--white);
      font-size: 14px;          /* +10% from 13px */
    }

    tbody td:nth-child(2) {
      text-align: left;
      color: var(--gray-light);
      font-size: 16px;        /* +10% from 12.5px */
    }

    /* ── Mobile scroll hint ── */
    .scroll-hint {
      display: none; /* hidden on desktop */
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-style: italic;
      color: var(--gray-mid);
      padding: 7px 2px 0;
      line-height: 1;
    }

    @media (max-width: 700px) {
      .scroll-hint { display: flex; }
    }

    /* ── 3HR note beneath table ── */
    .table-note {
      font-size: 12px;
      font-style: italic;
      color: var(--gray-mid);
      padding: 8px 2px 22px;
      line-height: 1.5;
    }

    /* ── TRUST STRIP ── */
    .trust-strip {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr auto;
      align-items: center;
      border-top: 1px solid var(--divider);
      padding-top: 24px;
    }

    .trust-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding-right: 28px;
      margin-right: 28px;
      border-right: 1px solid rgba(255,255,255,0.09);
    }

    .trust-icon { color: var(--red); flex-shrink: 0; }
    .trust-icon svg { width: 26px; height: 26px; }

    .trust-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 0.16em;
      color: var(--white);
      text-transform: uppercase;
      margin-bottom: 3px;
    }

    .trust-desc {
      font-size: 16px;
      color: var(--gray-mid);
      line-height: 1.45;
    }

    /* ── CTA Button — matches hero .btn-primary exactly ── */
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 44px 16px 36px;
      background: var(--red);
      color: var(--white);
      font-family: 'Barlow', sans-serif;
      font-weight: 600;
      font-size: 14px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-decoration: none;
      border: none;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
      flex-shrink: 0;
      white-space: nowrap;
      transform: skewX(-12deg);  /* parallelogram slant */
    }

    /* Counter-skew inner content so text stays upright */
    .cta-btn > * {
      display: inline-flex;
      align-items: center;
      transform: skewX(12deg);
    }

    .cta-btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .cta-btn:hover {
      background: var(--red-bright);
      transform: skewX(-12deg) translateY(-2px);
      box-shadow: 0 8px 30px rgba(193, 39, 45, 0.4);
    }

    .cta-btn:hover::after { opacity: 1; }
    .cta-btn:active { transform: skewX(-12deg) translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .pricing-content { padding: 44px 32px 36px; }
    }

    @media (max-width: 860px) {
      .pricing-header { grid-template-columns: 1fr; gap: 28px; }

      .trust-strip { grid-template-columns: 1fr 1fr; gap: 20px; }

      .trust-item {
        border-right: none;
        margin-right: 0;
        padding-right: 0;
      }

      .cta-btn {
        grid-column: 1 / -1;
        justify-content: center;
        width: 100%;
      }
    }

    @media (max-width: 580px) {
      .pricing-content { padding: 36px 20px 28px; }
      .badge { padding: 0 16px; }
      .badge:first-child { padding-left: 0; }
      .trust-strip { grid-template-columns: 1fr; }
    }
  </style>
</head>
