<style>
/* ─── RESET ──────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow-x:hidden;background:#08080a}

/* ─── VARS ───────────────────────────────────────── */
:root{
  --red:#c1272d;
  --red-glow:rgba(193,39,45,0.55);
  --bg:#08080a;
  --white:#ffffff;
  --white-60:rgba(255,255,255,0.60);
  --white-14:rgba(255,255,255,0.14);
}

/* ─── HERO SHELL ─────────────────────────────────── */
.hero{
  position:relative;
  width:100%;
  min-height:100vh;
  min-height:100svh;
  overflow:hidden;
  display:flex;
  align-items:stretch;
  background:var(--bg);
}

/* ─── DESKTOP BACKGROUND IMAGE (LCP) ────────────── */
/* Landscape — paints immediately as LCP element */
.hero__bg-img{
  position:absolute;
  inset:0;
  z-index:1;
  background-image:url('https://static.wixstatic.com/media/a30e59_3f9317aa58dc475e9684360413f33ba8~mv2.jpg');
  background-size:cover;
  background-position:center center;
  will-change:transform;
}

/* ─── VIDEO LAYER (fades in after LCP) ──────────── */
.hero__video{
  position:absolute;
  inset:0;
  z-index:2;
  opacity:0;
  transition:opacity 1.4s cubic-bezier(0.4,0,0.2,1);
  pointer-events:none;
}
.hero__video video{
  width:100%;
  height:100%;
  object-fit:cover;
  object-position:center center;
}
.hero__video.is-ready{opacity:1}

/* ─── ATMOSPHERE ─────────────────────────────────── */
/* Desktop veil: dark left for text, fades right */
.hero__veil{
  position:absolute;inset:0;z-index:3;
  background:linear-gradient(
    105deg,
    rgba(8,8,10,0.93) 0%,
    rgba(8,8,10,0.78) 35%,
    rgba(8,8,10,0.35) 62%,
    rgba(8,8,10,0.08) 100%
  );
}

/* Grain texture */
.hero__grain{
  position:absolute;inset:0;z-index:4;
  opacity:0.036;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-size:180px 180px;
  pointer-events:none;
}

/* Bottom vignette — bleeds into next section */
.hero__vignette{
  position:absolute;bottom:0;left:0;right:0;height:220px;z-index:4;
  background:linear-gradient(to bottom,transparent 0%,rgba(8,8,10,0.9) 100%);
  pointer-events:none;
}

/* Red left edge */
.hero__edge{
  position:absolute;top:0;left:0;bottom:0;width:3px;z-index:5;
  background:linear-gradient(180deg,transparent 0%,var(--red) 25%,var(--red) 75%,transparent 100%);
  pointer-events:none;
}

/* Scan line */
.hero__scan{
  position:absolute;left:0;right:0;height:1.5px;z-index:5;
  background:linear-gradient(90deg,transparent 0%,transparent 10%,rgba(193,39,45,0.65) 50%,transparent 90%,transparent 100%);
  animation:scan 8s linear infinite;
  pointer-events:none;
}
@keyframes scan{
  0%{top:-2px;opacity:0}3%{opacity:0.8}97%{opacity:0.8}100%{top:100%;opacity:0}
}

/* ─── CORNER BRACKETS ────────────────────────────── */
.bracket{
  position:absolute;width:48px;height:48px;z-index:8;
  pointer-events:none;opacity:0;
  animation:bracketIn 0.6s cubic-bezier(0.4,0,0.2,1) forwards;
}
.bracket--tl{top:24px;left:24px;border-top:1.5px solid var(--red);border-left:1.5px solid var(--red);animation-delay:0.3s}
.bracket--tr{top:24px;right:24px;border-top:1.5px solid var(--red);border-right:1.5px solid var(--red);animation-delay:0.45s}
.bracket--bl{bottom:24px;left:24px;border-bottom:1.5px solid var(--red);border-left:1.5px solid var(--red);animation-delay:0.6s}
.bracket--br{bottom:24px;right:24px;border-bottom:1.5px solid var(--red);border-right:1.5px solid var(--red);animation-delay:0.75s}
@keyframes bracketIn{to{opacity:1}}

.bracket::after{
  content:'';position:absolute;width:5px;height:5px;
  background:var(--red);border-radius:50%;
  box-shadow:0 0 8px 3px var(--red-glow);
  animation:pulse 3s ease-in-out infinite;
}
.bracket--tl::after{top:-2.5px;left:-2.5px}
.bracket--tr::after{top:-2.5px;right:-2.5px}
.bracket--bl::after{bottom:-2.5px;left:-2.5px}
.bracket--br::after{bottom:-2.5px;right:-2.5px}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.15;transform:scale(0.65)}}

/* ─── HUD LABELS ─────────────────────────────────── */
.hud{
  position:absolute;
  font-family:'Barlow Condensed',monospace;
  font-size:8.5px;letter-spacing:0.22em;text-transform:uppercase;
  color:rgba(255,255,255,0.18);z-index:8;pointer-events:none;
  opacity:0;animation:fadeUp 0.7s ease forwards;
}
.hud--tl{top:36px;left:84px;animation-delay:0.9s}
.hud--tr{top:36px;right:84px;text-align:right;animation-delay:1.0s}
.hud--bl{bottom:36px;left:84px;animation-delay:1.1s}
.hud--br{bottom:36px;right:84px;text-align:right;animation-delay:1.2s}

/* ─── CONTENT ────────────────────────────────────── */
.hero__inner{
  position:relative;z-index:10;
  width:100%;max-width:680px;
  padding:clamp(80px,10vh,120px) clamp(32px,5vw,72px) clamp(60px,8vh,100px);
  display:flex;flex-direction:column;
  align-items:flex-start;
  justify-content:center;
}

/* Eyebrow */
.hero__eyebrow{
  display:inline-flex;align-items:center;gap:12px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:10px;font-weight:600;letter-spacing:0.42em;
  text-transform:uppercase;color:var(--red);
  margin-bottom:20px;
  opacity:0;animation:fadeUp 0.7s ease forwards;animation-delay:0.2s;
}
.hero__eyebrow::before{
  content:'';display:block;width:22px;height:1px;
  background:var(--red);flex-shrink:0;
}

/* Headline */
.hero__headline{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(58px,7.5vw,108px);
  line-height:0.9;letter-spacing:0.01em;
  color:var(--white);
  opacity:0;animation:fadeUp 0.8s cubic-bezier(0.2,0,0,1) forwards;animation-delay:0.35s;
}
.hero__headline .accent{color:var(--red);display:block}
.hero__headline .ghost{
  color:transparent;
  -webkit-text-stroke:1.5px rgba(255,255,255,0.22);
  display:block;
}

/* Divider */
.hero__divider{
  display:flex;align-items:center;gap:14px;margin:22px 0 26px;
  opacity:0;animation:fadeUp 0.6s ease forwards;animation-delay:0.55s;
}
.hero__divider-line{height:1px;width:60px;background:linear-gradient(90deg,var(--red),transparent)}
.hero__divider-dot{width:5px;height:5px;background:var(--red);transform:rotate(45deg);box-shadow:0 0 8px 2px var(--red-glow)}

/* Body */
.hero__body{
  font-family:'Barlow',sans-serif;font-weight:300;
  font-size:clamp(14px,1.5vw,17px);line-height:1.75;
  color:var(--white-60);max-width:480px;
  margin-bottom:40px;letter-spacing:0.025em;
  opacity:0;animation:fadeUp 0.7s ease forwards;animation-delay:0.65s;
}

/* CTAs */
.hero__cta{
  display:flex;gap:14px;flex-wrap:wrap;margin-bottom:52px;
  opacity:0;animation:fadeUp 0.7s ease forwards;animation-delay:0.8s;
}

.btn{
  font-family:'Barlow Condensed',sans-serif;
  font-size:11px;font-weight:700;letter-spacing:0.28em;
  text-transform:uppercase;text-decoration:none;
  padding:16px 38px;
  display:inline-flex;align-items:center;gap:10px;
  cursor:pointer;border:none;
  position:relative;overflow:hidden;
  transition:all 0.3s cubic-bezier(0.4,0,0.2,1);
  white-space:nowrap;
}
.btn svg{width:12px;height:12px;fill:none;stroke:currentColor;stroke-width:2.5;flex-shrink:0;transition:transform 0.3s ease}
.btn:hover svg{transform:translateX(4px)}

.btn--primary{
  background:var(--red);color:var(--white);
  clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);
}
.btn--primary::before{
  content:'';position:absolute;inset:0;
  background:rgba(255,255,255,0.12);
  transform:translateX(-110%);
  transition:transform 0.32s cubic-bezier(0.4,0,0.2,1);
}
.btn--primary:hover::before{transform:translateX(0)}
.btn--primary:hover{box-shadow:0 0 32px var(--red-glow),0 8px 24px rgba(0,0,0,0.4)}

.btn--ghost{
  background:transparent;color:var(--white);
  border:1px solid rgba(255,255,255,0.28);
  clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);
}
.btn--ghost:hover{border-color:rgba(255,255,255,0.65);background:rgba(255,255,255,0.07)}

/* Stats */
.stat-strip{
  display:flex;align-items:center;
  opacity:0;animation:fadeUp 0.7s ease forwards;animation-delay:0.95s;
}
.stat{display:flex;flex-direction:column;padding:0 26px;position:relative}
.stat:first-child{padding-left:0}
.stat+.stat::before{
  content:'';position:absolute;left:0;top:10%;bottom:10%;
  width:1px;background:var(--white-14);
}
.stat__num{
  font-family:'Barlow Condensed',sans-serif;
  font-weight:800;font-size:clamp(28px,3.2vw,42px);
  line-height:1;color:var(--white);
}
.stat__num em{color:var(--red);font-style:normal}
.stat__lbl{
  font-family:'Barlow',sans-serif;
  font-size:9px;font-weight:500;
  letter-spacing:0.2em;text-transform:uppercase;
  color:rgba(255,255,255,0.35);margin-top:5px;
}

/* ─── ANIMATIONS ─────────────────────────────────── */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(18px)}
  to{opacity:1;transform:translateY(0)}
}

/* ─── MOBILE ─────────────────────────────────────── */
@media(max-width:768px){

  /* Mobile: vertical woman with walleye — shifted to show fish */
  .hero__bg-img{
    background-image:url('https://static.wixstatic.com/media/a30e59_6c68ef96330040e9b9fc7a4524e28e3a~mv2.jpeg');
    background-position:25% 12%;
  }

  /* Mobile video object position — shifted right to show fish */
  .hero__video video{
    object-position:25% 12%;
  }

  /* Mobile veil: top light, bottom dark — text sits at bottom */
  .hero__veil{
    background:linear-gradient(
      180deg,
      rgba(8,8,10,0.25) 0%,
      rgba(8,8,10,0.38) 38%,
      rgba(8,8,10,0.88) 68%,
      rgba(8,8,10,0.97) 100%
    );
  }

  /* Content to bottom of screen on mobile */
  .hero__inner{
    width:100%;
    max-width:100%;
    padding:80px 24px 48px;
    justify-content:flex-end;
    min-height:100svh;
    align-items:center;
    text-align:center;
  }

  .hero__eyebrow{justify-content:center}
  .hero__eyebrow::before{display:none}
  .hero__body{max-width:100%}
  .hero__cta{justify-content:center;gap:12px;margin-bottom:36px}
  .btn{font-size:10px;padding:14px 28px}
  .stat-strip{justify-content:center}
  .stat{padding:0 18px}
  .hud{display:none}
  .hero__edge{display:none}
  .hero__scan{display:none}
  .hero__eyebrow{display:none}
  .bracket{width:32px;height:32px}
  .bracket--tl,.bracket--tr{top:14px}
  .bracket--bl,.bracket--br{bottom:14px}
  .bracket--tl,.bracket--bl{left:14px}
  .bracket--tr,.bracket--br{right:14px}
}

@media(max-width:400px){
  .hero__headline{font-size:clamp(46px,13vw,60px)}
  .stat-strip{flex-wrap:wrap;gap:8px;justify-content:center}
  .stat{padding:0 14px}
}
</style>
</head>
