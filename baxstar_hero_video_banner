<script>
(function(){
  var DESKTOP_VIDEO = 'https://video.wixstatic.com/video/a30e59_b669034e86544337986851fd1c6d613f/1080p/mp4/file.mp4';
  var MOBILE_VIDEO  = 'https://video.wixstatic.com/video/a30e59_7c53d22fbb7641f0a1bbf08c2a000c93/720p/mp4/file.mp4';

  var isMobile = window.innerWidth <= 768;
  var videoSrc = isMobile ? MOBILE_VIDEO : DESKTOP_VIDEO;

  var videoWrap = document.getElementById('heroVideo');
  var videoEl   = videoWrap ? videoWrap.querySelector('video') : null;
  if(!videoEl) return;

  // Inject correct source
  var source = document.createElement('source');
  source.src  = videoSrc;
  source.type = 'video/mp4';
  videoEl.appendChild(source);

  // Load video after first paint — LCP is already done
  var loadVideo = function(){
    videoEl.addEventListener('canplaythrough', function onReady(){
      videoEl.removeEventListener('canplaythrough', onReady);
      setTimeout(function(){ videoWrap.classList.add('is-ready'); }, 200);
    });
    videoEl.load();
    videoEl.play().catch(function(){
      // Autoplay blocked — static image stays visible, no broken state
    });
  };

  if('requestIdleCallback' in window){
    requestIdleCallback(loadVideo, {timeout:2000});
  } else {
    setTimeout(loadVideo, 1500);
  }
})();
</script>

