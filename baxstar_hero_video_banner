  var VIDEO_SD = 'https://video.wixstatic.com/video/a30e59_7c53d22fbb7641f0a1bbf08c2a000c93/720p/mp4/file.mp4#t=0.001';

  var videoWrap = document.getElementById('heroVideo');
  var videoEl = videoWrap ? videoWrap.querySelector('video') : null;
  if(!videoEl) return;

  function addSource(src){
    var s = document.createElement('source');
    s.src = src;
    s.type = 'video/mp4';
    videoEl.appendChild(s);
  }

  videoEl.addEventListener('error', function fallback(){
    while (videoEl.firstChild) videoEl.removeChild(videoEl.firstChild);
    addSource(VIDEO_SD);
    videoEl.removeEventListener('error', fallback);
    videoEl.load();
    videoEl.play().catch(function(){});
  }, { once: true, passive: true });

  addSource(VIDEO_HD);
  addSource(VIDEO_SD);

  var loadVideo = function(){
    videoEl.addEventListener('canplaythrough', function onReady(){
      videoEl.removeEventListener('canplaythrough', onReady);
      // Snap to video — 0.15s opacity transition is perceived as "video starts" not "image fades"
      requestAnimationFrame(function(){ videoWrap.classList.add('is-ready'); });
    }, { passive: true });
    videoEl.load();
    videoEl.play().catch(function(){});
  };

  if('requestIdleCallback' in window){ requestIdleCallback(loadVideo, {timeout:2000}); }
  else { setTimeout(loadVideo, 1500); }

  // Pause video when tab is hidden — saves battery and stops compositor work
  document.addEventListener('visibilitychange', function(){
    if (document.hidden) {
      try { videoEl.pause(); } catch(e){}
    } else {
      try { videoEl.play().catch(function(){}); } catch(e){}
    }
  }, { passive: true });
})();
</script>

<!-- IFRAME HEIGHT REPORTER — auto-resizes Wix Custom Embed iframe -->
<script>
(function(){
  if (window.parent === window) return;
  var lastH = 0;
  var stableCount = 0;
  var intervalId = null;

  function report(){
    var h = Math.max(document.documentElement.scrollHeight, document.body ? document.body.scrollHeight : 0);
    if (h && h !== lastH) {
      lastH = h;
      stableCount = 0;
      try { window.parent.postMessage({ type: 'setHeight', height: h }, '*'); } catch(e){}
      try { window.parent.postMessage({ type: 'embed-size', height: h }, '*'); } catch(e){}
      try { window.parent.postMessage('height:' + h, '*'); } catch(e){}
    } else {
      stableCount++;
      // After 20 stable reports (~30 seconds), stop the interval to free the main thread
      if (stableCount >= 20 && intervalId) {
        clearInterval(intervalId);
        intervalId = null;
      }
    }
  }

  window.addEventListener('load', report, { passive: true });
  window.addEventListener('resize', function(){
    stableCount = 0;
    // Restart interval on resize if it had stopped
    if (!intervalId) intervalId = setInterval(report, 1500);
    report();
  }, { passive: true });

  if (window.ResizeObserver) {
    try {
      new ResizeObserver(function(){
        stableCount = 0;
        if (!intervalId) intervalId = setInterval(report, 1500);
        report();
      }).observe(document.body);
    } catch(e){}
  }

  intervalId = setInterval(report, 1500);
})();
</script>

