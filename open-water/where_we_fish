<script>
(function(){
  'use strict';
  var $ = function(s,r){return (r||document).querySelector(s)};
  var $$ = function(s,r){return Array.prototype.slice.call((r||document).querySelectorAll(s))};
  var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ===== 1. SCROLL REVEAL — staggered fade-up =====
  var revealEls = $$('.reveal');
  if(prefersReduced){
    revealEls.forEach(function(el){el.classList.add('visible')});
  }else if('IntersectionObserver' in window){
    revealEls.forEach(function(el,i){
      el.style.transitionDelay = (i*0.05) + 's';
    });
    var revealObs = new IntersectionObserver(function(entries){
      entries.forEach(function(en){
        if(en.isIntersecting){
          var t = en.target;
          requestAnimationFrame(function(){t.classList.add('visible')});
          revealObs.unobserve(t);
        }
      });
    },{threshold:0.18,rootMargin:'0px 0px -8% 0px'});
    revealEls.forEach(function(el){revealObs.observe(el)});
  }

  // ===== 2. MAP REVEAL — triggers connector + scan + markers =====
  var mapFrame = $('#mapFrame');
  var mapSvg = $('#mapSvg');
  if(mapFrame && 'IntersectionObserver' in window){
    var mapObs = new IntersectionObserver(function(entries){
      entries.forEach(function(en){
        if(en.isIntersecting){
          requestAnimationFrame(function(){
            mapFrame.classList.add('is-revealed');
            mapSvg && mapSvg.classList.add('is-revealed');
          });
          mapObs.unobserve(en.target);
        }
      });
    },{threshold:0.25});
    mapObs.observe(mapFrame);
  }else if(mapFrame){
    mapFrame.classList.add('is-revealed');
    mapSvg && mapSvg.classList.add('is-revealed');
  }

  // ===== 3. CARDS ⇄ MAP SYNC — active card highlights its lake =====
  var cards = $$('.lake-card');
  var markers = $$('.marker');
  var waterShapes = $$('.water-shape');
  var lakeLabels = $$('.lake-label');

  function setActiveLake(lakeId){
    cards.forEach(function(c){c.classList.toggle('is-active', c.dataset.lake === lakeId)});
    markers.forEach(function(m){m.classList.toggle('is-active', m.dataset.lake === lakeId)});
    waterShapes.forEach(function(s){s.classList.toggle('is-active', s.dataset.lake === lakeId)});
    lakeLabels.forEach(function(l){l.classList.toggle('is-active', l.dataset.lake === lakeId)});
  }

  // Card-in-view → set active
  if('IntersectionObserver' in window && cards.length){
    var lastActive = null;
    var inView = {};
    var cardSyncObs = new IntersectionObserver(function(entries){
      entries.forEach(function(en){
        var id = en.target.dataset.lake;
        if(en.isIntersecting){ inView[id] = en.intersectionRatio; }
        else { delete inView[id]; }
      });
      // Pick the card with the largest visibility ratio
      var bestId = null, bestRatio = 0;
      Object.keys(inView).forEach(function(k){
        if(inView[k] > bestRatio){ bestRatio = inView[k]; bestId = k; }
      });
      if(bestId && bestId !== lastActive){
        lastActive = bestId;
        // Reveal card on first sight
        cards.forEach(function(c){if(c.dataset.lake===bestId)c.classList.add('is-revealed')});
        setActiveLake(bestId);
      }
    },{threshold:[0,0.3,0.55,0.8,1],rootMargin:'-20% 0px -20% 0px'});
    cards.forEach(function(c){cardSyncObs.observe(c)});
  }else{
    // Fallback: reveal everything
    cards.forEach(function(c){c.classList.add('is-revealed')});
  }

  // ===== 4. MARKER CLICK → scroll to its card =====
  markers.forEach(function(m){
    m.addEventListener('click', function(e){
      var id = m.dataset.lake;
      var target = document.getElementById('card-' + id);
      if(!target) return;
      var rect = target.getBoundingClientRect();
      var top = rect.top + (window.pageYOffset || document.documentElement.scrollTop) - (window.innerHeight*0.18);
      try{
        // Tell the parent Wix page to scroll (since we're in an iframe)
        parent.postMessage({type:'baxstar_scroll_to', y: top, lake: id},'*');
      }catch(err){}
      // Local scroll fallback (works if not in iframe or when sandbox allows)
      try{
        window.scrollTo({top: top, behavior: prefersReduced ? 'auto' : 'smooth'});
      }catch(err){
        window.scrollTo(0, top);
      }
      // Snap visual state immediately
      setActiveLake(id);
    },{passive:true});
  });

  // ===== 5. CTA TRACKING — fire postMessage events to parent =====
  $$('[data-track]').forEach(function(a){
    a.addEventListener('click', function(){
      try{ parent.postMessage({type:'baxstar_event',event:a.dataset.track,location:'lake_atlas'},'*'); }catch(e){}
    },{passive:true});
  });

  // ===== 6. PERSPECTIVE TILT ON MAP — subtle scroll-driven rotateX =====
  // (skipped for prefers-reduced-motion)
  if(!prefersReduced && mapFrame && window.innerWidth > 980){
    var ticking = false;
    function updateTilt(){
      var rect = mapFrame.getBoundingClientRect();
      var winH = window.innerHeight;
      // -1 above, 0 centered, 1 below
      var pos = (rect.top + rect.height/2 - winH/2) / winH;
      pos = Math.max(-1, Math.min(1, pos));
      var tilt = pos * 4; // up to 4deg
      mapFrame.style.transform = 'perspective(1400px) rotateX(' + (-tilt) + 'deg)';
      ticking = false;
    }
    window.addEventListener('scroll', function(){
      if(!ticking){ requestAnimationFrame(updateTilt); ticking = true; }
    },{passive:true});
    updateTilt();
  }

  // ===== 7. IFRAME HEIGHT REPORTER (Wix Custom Embed) =====
  if(window.parent !== window){
    var lastH = 0, stable = 0, intId = null;
    function reportHeight(){
      var h = Math.max(
        document.documentElement.scrollHeight,
        document.body ? document.body.scrollHeight : 0
      );
      if(h && h !== lastH){
        lastH = h; stable = 0;
        try{parent.postMessage({type:'setHeight',height:h},'*')}catch(e){}
        try{parent.postMessage({type:'embed-size',height:h},'*')}catch(e){}
        try{parent.postMessage('height:'+h,'*')}catch(e){}
      } else if(++stable >= 20 && intId){
        clearInterval(intId); intId = null;
      }
    }
    window.addEventListener('load', reportHeight, {passive:true});
    window.addEventListener('resize', function(){
      stable = 0; if(!intId) intId = setInterval(reportHeight, 1500); reportHeight();
    },{passive:true});
    if(window.ResizeObserver){
      try{ new ResizeObserver(function(){
        stable = 0; if(!intId) intId = setInterval(reportHeight, 1500);
      }).observe(document.body); }catch(e){}
    }
    intId = setInterval(reportHeight, 1500);
  }
})();
</script>
