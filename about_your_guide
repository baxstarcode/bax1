<style>
  /* ───────── DESIGN TOKENS ───────── */
  :root {
    --bx-black: #08080a;
    --bx-near-black: #0d0d11;
    --bx-graphite: #14151a;
    --bx-card: #17181e;
    --bx-slate: #2a2d36;
    --bx-fog: #4a5560;
    --bx-bone: #c8c5bd;
    --bx-pearl: #e8e6e0;

    --bx-red: #e63946;
    --bx-red-deep: #c1272d;
    --bx-red-glow: rgba(230, 57, 70, 0.45);
    --bx-cyan: #1ce3d2;

    --font-display: 'Bebas Neue', 'Impact', sans-serif;
    --font-tactical: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    --font-body: 'Barlow', 'Helvetica Neue', sans-serif;
    --font-italic: 'Cormorant Garamond', Georgia, serif;
    --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-text-size-adjust: 100%; }
  body {
    background: var(--bx-black);
    color: var(--bx-pearl);
    font-family: var(--font-body);
    font-weight: 300;
    overscroll-behavior: none;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    line-height: 1.5;
  }

  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  /* ───────── REVEAL ENGINE ───────── */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.95s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.95s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform, opacity;
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
    will-change: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }

  /* ───────── DOSSIER SHELL ───────── */
  .dossier {
    position: relative;
    width: 100%;
    background: var(--bx-black);
    color: var(--bx-pearl);
    overflow: hidden;
    isolation: isolate;
  }
  .dossier::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 80% 10%, rgba(230, 57, 70, 0.06), transparent 70%),
      radial-gradient(ellipse 60% 50% at 20% 80%, rgba(28, 227, 210, 0.04), transparent 70%);
    z-index: 0;
    pointer-events: none;
  }

  /* ───────── HERO ───────── */
  .hero {
    position: relative;
    z-index: 2;
    min-height: clamp(560px, 88vh, 920px);
    padding: clamp(88px, 11vw, 160px) clamp(20px, 4vw, 56px) clamp(64px, 8vw, 120px);
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(32px, 4vw, 80px);
    align-items: center;
    max-width: 1440px;
    margin: 0 auto;
  }

  .hero__copy { position: relative; z-index: 2; }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-tactical);
    font-weight: 500;
    font-size: clamp(11px, 1vw, 13px);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--bx-red);
    margin: 0 0 26px;
  }
  .eyebrow::before {
    content: "";
    width: 32px;
    height: 1px;
    background: var(--bx-red);
    box-shadow: 0 0 10px var(--bx-red-glow);
  }
  .eyebrow .doc-id {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--bx-fog);
    letter-spacing: 0.12em;
    margin-left: auto;
  }

  .hero__name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(64px, 12vw, 192px);
    line-height: 0.84;
    letter-spacing: -0.012em;
    color: var(--bx-pearl);
    text-transform: uppercase;
    margin: 0;
  }
  .hero__name span {
    display: block;
  }
  .hero__name .surname {
    color: var(--bx-bone);
  }

  .hero__tagline {
    font-family: var(--font-italic);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(20px, 2.4vw, 32px);
    line-height: 1.25;
    color: var(--bx-bone);
    margin: clamp(28px, 3vw, 44px) 0 0;
    max-width: 22ch;
  }
  .hero__tagline strong {
    font-style: normal;
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--bx-pearl);
    letter-spacing: 0.02em;
  }

  .hero__bluf {
    font-size: clamp(16px, 1.4vw, 18px);
    line-height: 1.6;
    color: var(--bx-bone);
    max-width: 52ch;
    margin: clamp(28px, 3vw, 40px) 0 0;
  }
  .hero__bluf strong { color: var(--bx-pearl); font-weight: 500; }

  /* Hero portrait frame */
  .hero__portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    width: 100%;
    max-width: 540px;
    justify-self: end;
    background: var(--bx-graphite);
    overflow: hidden;
  }
  .hero__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: contrast(1.05) saturate(0.92);
  }
  .hero__portrait::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(8, 8, 10, 0.55) 100%);
    z-index: 2;
    pointer-events: none;
  }
  .hero__portrait::after {
    content: "";
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(232, 230, 224, 0.12);
    z-index: 3;
    pointer-events: none;
  }
  .hero__portrait-tag {
    position: absolute;
    bottom: 24px;
    left: 24px;
    z-index: 4;
    font-family: var(--font-tactical);
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--bx-bone);
  }
  .hero__portrait-tag .key { color: var(--bx-fog); margin-right: 8px; }
  .hero__portrait-tag .val { color: var(--bx-red); }

  /* ───────── NUMBERS STRIP ───────── */
  .numbers {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--bx-slate);
    border-bottom: 1px solid var(--bx-slate);
    background: rgba(13, 13, 17, 0.6);
  }
  .numbers__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: clamp(36px, 4vw, 56px) clamp(20px, 4vw, 56px);
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: clamp(16px, 2vw, 32px);
  }
  .stat { position: relative; }
  .stat:not(:last-child)::after {
    content: "";
    position: absolute;
    right: -16px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--bx-slate);
  }
  .stat__num {
    font-family: var(--font-display);
    font-size: clamp(44px, 5.5vw, 84px);
    line-height: 0.9;
    color: var(--bx-pearl);
    letter-spacing: 0;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .stat__num sup {
    font-size: 0.42em;
    color: var(--bx-red);
    font-family: var(--font-tactical);
    font-weight: 600;
    letter-spacing: 0.08em;
    top: -0.4em;
    position: relative;
  }
  .stat__label {
    font-family: var(--font-tactical);
    font-size: clamp(10px, 0.95vw, 12px);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--bx-bone);
    margin-top: 8px;
    line-height: 1.3;
  }

  /* ───────── ORIGIN CHAPTER ───────── */
  .origin {
    position: relative;
    z-index: 2;
    max-width: 880px;
    margin: 0 auto;
    padding: clamp(80px, 10vw, 140px) clamp(20px, 4vw, 56px);
    text-align: center;
  }
  .origin__quote {
    font-family: var(--font-italic);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(24px, 3.2vw, 42px);
    line-height: 1.35;
    color: var(--bx-pearl);
    margin: 24px 0 0;
  }
  .origin__quote::before,
  .origin__quote::after {
    content: "";
    display: block;
    width: 40px;
    height: 1px;
    background: var(--bx-red);
    margin: 32px auto;
    opacity: 0.7;
  }
  .origin__attr {
    font-family: var(--font-tactical);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--bx-fog);
    margin-top: 24px;
  }

  /* ───────── SIX LIVES SECTION ───────── */
  .lives {
    position: relative;
    z-index: 2;
    max-width: 1440px;
    margin: 0 auto;
    padding: clamp(64px, 8vw, 120px) clamp(20px, 4vw, 56px) clamp(80px, 9vw, 140px);
  }
  .lives__head {
    display: grid;
    grid-template-columns: 0.6fr 1.4fr;
    gap: clamp(24px, 3vw, 56px);
    margin-bottom: clamp(48px, 6vw, 88px);
    align-items: end;
  }
  .lives__head-tagline {
    font-family: var(--font-italic);
    font-style: italic;
    font-size: clamp(18px, 1.8vw, 22px);
    line-height: 1.5;
    color: var(--bx-bone);
    max-width: 56ch;
  }
  .lives__head-tagline strong {
    font-style: normal;
    color: var(--bx-pearl);
    font-weight: 500;
  }
  .lives__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(56px, 8vw, 116px);
    line-height: 0.9;
    letter-spacing: -0.005em;
    color: var(--bx-pearl);
    text-transform: uppercase;
    margin: 0;
  }
  .lives__title em {
    font-family: var(--font-italic);
    font-style: italic;
    color: var(--bx-bone);
    font-size: 0.42em;
    display: block;
    text-transform: none;
    letter-spacing: 0;
    margin-top: 0.4em;
    line-height: 1.1;
  }

  .lives__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 1.8vw, 28px);
  }

  /* ──── INDIVIDUAL CHAPTER CARDS ──── */
  .chapter {
    position: relative;
    background: var(--bx-card);
    border: 1px solid var(--bx-slate);
    overflow: hidden;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.5s ease,
      box-shadow 0.5s ease;
  }
  .chapter:hover {
    transform: translateY(-4px);
    border-color: var(--bx-fog);
    box-shadow: 0 24px 48px -24px rgba(0, 0, 0, 0.8), 0 0 0 1px rgba(230, 57, 70, 0.18);
  }
  .chapter:hover .chapter__img img {
    transform: scale(1.06);
  }
  .chapter:hover .chapter__num {
    color: var(--bx-red);
  }

  .chapter__img {
    position: relative;
    aspect-ratio: 5 / 4;
    background: var(--bx-near-black);
    overflow: hidden;
  }
  .chapter__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.95s cubic-bezier(0.22, 1, 0.36, 1);
    filter: contrast(1.04) saturate(0.9);
  }
  .chapter__img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(20, 21, 26, 0.85) 100%);
    pointer-events: none;
  }

/* Image slot — hides cleanly when src=""  */
  .chapter__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.95s cubic-bezier(0.22, 1, 0.36, 1);
    filter: contrast(1.04) saturate(0.9);
    position: relative;
    z-index: 1;
  }
  .chapter__photo[src=""],
  .chapter__photo:not([src]) {
    display: none;
  }
  .chapter:hover .chapter__photo {
    transform: scale(1.06);
  }
  /* Soft branded fallback when no image is supplied — shown via the existing .chapter__placeholder structure */

  .chapter__placeholder {
    /* Used when an image isn't supplied — visible scaffold for Brady to drop assets in */
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      linear-gradient(135deg, var(--bx-graphite) 0%, var(--bx-near-black) 100%);
  }
  .chapter__placeholder svg { width: 64px; height: 64px; opacity: 0.18; }

  .chapter__num {
    position: absolute;
    top: 18px;
    left: 18px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--bx-bone);
    background: rgba(8, 8, 10, 0.7);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 6px 10px;
    border: 1px solid rgba(232, 230, 224, 0.12);
    transition: color 0.5s ease;
  }

  .chapter__body {
    padding: clamp(22px, 2.4vw, 32px);
  }
  .chapter__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 2.8vw, 36px);
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--bx-pearl);
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  .chapter__sub {
    font-family: var(--font-italic);
    font-style: italic;
    font-size: clamp(14px, 1.2vw, 16px);
    color: var(--bx-bone);
    line-height: 1.4;
    margin: 0 0 22px;
  }
  .chapter__copy {
    font-size: clamp(14px, 1.05vw, 15px);
    line-height: 1.65;
    color: var(--bx-bone);
    margin: 0 0 22px;
  }
  .chapter__copy strong { color: var(--bx-pearl); font-weight: 500; }

  .chapter__connect {
    border-top: 1px solid var(--bx-slate);
    padding-top: 18px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: start;
  }
  .chapter__connect-label {
    font-family: var(--font-tactical);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--bx-red);
    line-height: 1.4;
    padding-top: 2px;
    white-space: nowrap;
  }
  .chapter__connect-text {
    font-size: clamp(13px, 1vw, 14px);
    line-height: 1.55;
    color: var(--bx-pearl);
    font-weight: 400;
  }

  /* ───────── CONNECTION PANEL ───────── */
  .connect {
    position: relative;
    z-index: 2;
    background: linear-gradient(180deg, transparent 0%, rgba(13, 13, 17, 0.7) 50%, transparent 100%);
    padding: clamp(80px, 10vw, 140px) clamp(20px, 4vw, 56px);
    border-top: 1px solid var(--bx-slate);
    border-bottom: 1px solid var(--bx-slate);
  }
  .connect__inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .connect__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(40px, 5.5vw, 80px);
    line-height: 1;
    letter-spacing: 0;
    color: var(--bx-pearl);
    text-transform: uppercase;
    margin: 0 0 28px;
  }
  .connect__title em {
    font-family: var(--font-italic);
    font-style: italic;
    color: var(--bx-bone);
    font-size: 0.5em;
    display: block;
    text-transform: none;
    margin-top: 0.3em;
    letter-spacing: 0;
  }
  .connect__copy {
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.65;
    color: var(--bx-bone);
    max-width: 64ch;
    margin: 0 auto;
  }
  .connect__copy strong { color: var(--bx-pearl); font-weight: 500; }

  .connect__pairs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(16px, 2vw, 28px) clamp(24px, 3vw, 48px);
    margin-top: clamp(48px, 5vw, 72px);
    text-align: left;
  }
  .pair {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 16px;
    align-items: center;
    padding: 18px 0;
    border-top: 1px solid var(--bx-slate);
  }
  .pair__client {
    font-family: var(--font-italic);
    font-style: italic;
    font-size: clamp(14px, 1.2vw, 16px);
    color: var(--bx-bone);
    line-height: 1.4;
  }
  .pair__arrow {
    font-family: var(--font-mono);
    color: var(--bx-red);
    font-size: 14px;
  }
  .pair__life {
    font-family: var(--font-tactical);
    font-size: clamp(11px, 1vw, 13px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bx-pearl);
    font-weight: 600;
  }

  /* ───────── PRESS STRIP ───────── */
  .press {
    position: relative;
    z-index: 2;
    max-width: 1440px;
    margin: 0 auto;
    padding: clamp(56px, 6vw, 88px) clamp(20px, 4vw, 56px);
    text-align: center;
  }
  .press__label {
    font-family: var(--font-tactical);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--bx-fog);
    margin-bottom: 28px;
  }
  .press__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: clamp(24px, 4vw, 56px);
    list-style: none;
  }
  .press__list li {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 28px);
    color: var(--bx-bone);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.65;
    transition: opacity 0.4s ease, color 0.4s ease;
  }
  .press__list li:hover { opacity: 1; color: var(--bx-pearl); }

  /* ───────── CTA ───────── */
  .cta-final {
    position: relative;
    z-index: 2;
    padding: clamp(72px, 9vw, 128px) clamp(20px, 4vw, 56px);
    border-top: 1px solid var(--bx-slate);
    background: linear-gradient(180deg, transparent 0%, rgba(13, 13, 17, 0.8) 100%);
  }
  .cta-final__inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .cta-final__lede {
    font-family: var(--font-italic);
    font-style: italic;
    font-size: clamp(20px, 2vw, 26px);
    color: var(--bx-bone);
    margin: 0 0 16px;
  }
  .cta-final__head {
    font-family: var(--font-display);
    font-weight: 400;
