  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}

    :root{
      --black:#08080a;
      --charcoal:#0d0d10;
      --red:#c1272d;
      --red-bright:#e63946;
      --red-glow:rgba(193,39,45,0.55);
      --cream:#f0ece4;
      --white:#fff;
      --gray-light:#d4d0c9;
      --gray-mid:#8f8f9a;
      --gold:#c9a84c;
      --divider:rgba(255,255,255,0.08);
      --divider-strong:rgba(255,255,255,0.14);
      --ease:cubic-bezier(0.4,0,0.2,1);
      --ease-out:cubic-bezier(0.2,0.8,0.2,1);
    }

    body{
      overscroll-behavior:none;
      background:var(--black);
      font-family:'Barlow',sans-serif;
      -webkit-font-smoothing:antialiased;
      color:var(--cream);
    }

    .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

    /* ── SECTION ───────────────────────────── */
    .pricing-min{
      position:relative;
      width:100%;
      background:var(--black);
      overflow:hidden;
    }

    .pricing-min__bg{
      position:absolute;inset:0;z-index:0;
      background:
        radial-gradient(ellipse at 92% 28%, rgba(122,24,8,0.45) 0%, rgba(74,13,5,0.18) 35%, transparent 65%),
        radial-gradient(ellipse at 5% 85%, rgba(122,24,8,0.20) 0%, transparent 55%),
        var(--black);
    }
    .pricing-min__bg::after{
      content:'';position:absolute;inset:0;opacity:0.035;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size:200px 200px;
    }

    .pricing-min__content{
      position:relative;z-index:2;
      max-width:1080px;margin:0 auto;
      padding:clamp(72px,10vw,128px) clamp(28px,5vw,72px) clamp(56px,8vw,96px);
    }

    /* ── HEADER ──────────────────────────── */
    .pmin-header{
      text-align:center;
      max-width:680px;
      margin:0 auto clamp(56px,7vw,88px);
    }
    .pmin-eyebrow{
      display:inline-flex;align-items:center;gap:14px;
      font-family:'Barlow Condensed',sans-serif;
      font-size:11px;font-weight:600;
      letter-spacing:0.32em;text-transform:uppercase;
      color:var(--red-bright);
      margin-bottom:20px;
    }
    .pmin-eyebrow::before,.pmin-eyebrow::after{
      content:'';width:24px;height:1px;background:var(--red);
    }
    .pmin-headline{
      font-family:'Bebas Neue',sans-serif;
      font-size:clamp(56px,8vw,96px);
      line-height:0.92;letter-spacing:0.01em;
      color:var(--white);
      margin-bottom:22px;
      position:relative;
    }
    .pmin-headline .accent{color:var(--red);font-style:normal}
    .pmin-italic{
      display:block;
      font-family:'Cormorant Garamond',serif;
      font-style:italic;font-weight:400;
      font-size:0.34em;
      line-height:1;
      letter-spacing:0.01em;
      color:var(--gold);
      margin-bottom:-0.05em;
    }
    .pmin-subhead{
      font-size:clamp(15px,1.5vw,17px);
      font-weight:300;line-height:1.7;
      color:var(--gray-light);
      max-width:520px;margin:0 auto;
      letter-spacing:0.005em;
    }

    /* ── MENU ROWS ────────────────────────── */
    .pmin-menu{
      list-style:none;
      border-top:1px solid var(--divider-strong);
      margin-bottom:24px;
    }
    .pmin-row{
      position:relative;
      width:100%;
      display:grid;
      grid-template-columns:auto 1fr auto auto;
      align-items:center;
      gap:clamp(20px,3vw,40px);
      padding:clamp(28px,3.4vw,38px) clamp(8px,2vw,20px) clamp(22px,3vw,32px);
      border-bottom:1px solid var(--divider-strong);
      cursor:pointer;
      background:transparent;
      text-align:left;
      transition:background 0.32s var(--ease), padding-left 0.32s var(--ease-out);
    }
    .pmin-row::before{
      content:'';
      position:absolute;
      left:0;top:0;bottom:0;
      width:0;
      background:linear-gradient(90deg, var(--red) 0%, transparent 100%);
      opacity:0;
      transition:width 0.42s var(--ease-out), opacity 0.3s var(--ease);
    }
    .pmin-row:hover{
      background:rgba(193,39,45,0.04);
      padding-left:clamp(22px,3.5vw,40px);
    }
    .pmin-row:hover::before{
      width:3px;opacity:1;
    }

    .pmin-row__num{
      font-family:'Barlow Condensed',sans-serif;
      font-weight:600;
      font-size:11px;
      letter-spacing:0.28em;
      color:var(--gray-mid);
      flex-shrink:0;
      min-width:42px;
      transition:color 0.3s var(--ease);
    }
    .pmin-row:hover .pmin-row__num{color:var(--red-bright)}

    .pmin-row__main{min-width:0}
    .pmin-row__title{
      font-family:'Bebas Neue',sans-serif;
      font-size:clamp(28px,3.6vw,42px);
      line-height:1;letter-spacing:0.018em;
      color:var(--white);
      margin-bottom:5px;
      transition:color 0.3s var(--ease);
    }
    .pmin-row:hover .pmin-row__title{color:var(--red-bright)}
    .pmin-row__sub{
      font-family:'Cormorant Garamond',serif;
      font-style:italic;
      font-size:clamp(15px,1.45vw,17px);
      color:var(--gray-mid);
      letter-spacing:0.01em;
      line-height:1.4;
      padding-left:96px;
      max-width:100%;
      text-wrap:balance;
    }

    .pmin-row__from{
      font-family:'Barlow Condensed',sans-serif;
      font-weight:500;
      font-size:11px;
      letter-spacing:0.22em;
      text-transform:uppercase;
      color:var(--gray-mid);
      display:block;
      margin-bottom:3px;
    }
    .pmin-row__amount{
      font-family:'Bebas Neue',sans-serif;
      font-size:clamp(30px,4vw,44px);
      line-height:1;letter-spacing:0.012em;
      color:var(--white);
    }

    .pmin-row__arrow{
      width:34px;height:34px;
      display:flex;align-items:center;justify-content:center;
      border:1px solid var(--divider-strong);
      border-radius:50%;
      color:var(--gray-mid);
      transition:transform 0.4s var(--ease-out), border-color 0.3s var(--ease), background 0.3s var(--ease), color 0.3s var(--ease);
      flex-shrink:0;
    }
    .pmin-row__arrow svg{
      width:13px;height:13px;
      transition:transform 0.4s var(--ease-out);
    }
    .pmin-row:hover .pmin-row__arrow{
      border-color:var(--red);
      background:var(--red);
      color:var(--white);
      transform:rotate(-45deg);
    }

    /* Most popular badge — now sits directly above "From / $price" column */
    .pmin-row__price{
      text-align:right;
      flex-shrink:0;
      position:relative;
    }
    .pmin-popular{
      position:absolute;
      bottom:calc(100% + 8px);
      right:0;
      font-family:'Barlow Condensed',sans-serif;
      font-size:9.5px;font-weight:700;
      letter-spacing:0.26em;text-transform:uppercase;
      color:var(--gold);
      padding:3px 8px;
      border:1px solid rgba(201,168,76,0.32);
      background:rgba(201,168,76,0.06);
      border-radius:1px;
      pointer-events:none;
      white-space:nowrap;
    }

    /* ── FOOTNOTE ────────────────────────── */
    .pmin-foot{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      flex-wrap:wrap;
      gap:14px;
      font-size:13px;
      color:var(--gray-mid);
      line-height:1.55;
      letter-spacing:0.01em;
      padding:0 clamp(8px,2vw,20px);
    }
    .pmin-foot__left{font-style:italic;flex:1;min-width:240px}
    .pmin-foot__right{
      display:inline-flex;align-items:center;gap:8px;
      font-family:'Barlow Condensed',sans-serif;
      font-style:normal;
      font-weight:600;
      font-size:11.5px;letter-spacing:0.18em;text-transform:uppercase;
      color:var(--red-bright);
    }
    .pmin-foot__right svg{
      width:12px;height:12px;
      animation:tap-pulse 2.4s ease-in-out infinite;
    }
    @keyframes tap-pulse{
      0%,100%{transform:translateY(0);opacity:1}
      50%{transform:translateY(-3px);opacity:0.6}
    }

    /* ── CTA STRIP ───────────────────────── */
    .pmin-cta-strip{
      margin-top:clamp(48px,6vw,72px);
      padding-top:clamp(36px,5vw,52px);
      border-top:1px solid var(--divider);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:32px;
      flex-wrap:wrap;
    }
    .pmin-trust{
      display:flex;
      align-items:center;
      gap:32px;
      flex-wrap:wrap;
    }
    .pmin-trust__item{
      display:flex;flex-direction:column;
    }
    .pmin-trust__num{
      font-family:'Bebas Neue',sans-serif;
      font-size:30px;line-height:1;
      color:var(--white);
      letter-spacing:0.012em;
    }
    .pmin-trust__num em{
      font-style:normal;color:var(--red);
    }
    .pmin-trust__label{
      font-family:'Barlow Condensed',sans-serif;
      font-size:10.5px;
      font-weight:500;
      letter-spacing:0.22em;text-transform:uppercase;
      color:var(--gray-mid);
      margin-top:6px;
    }

    .pmin-cta{
      display:inline-flex;align-items:center;gap:11px;
      padding:16px 44px 16px 36px;
      background:var(--red);color:var(--white);
      font-family:'Barlow',sans-serif;
      font-weight:600;font-size:14px;letter-spacing:1.5px;text-transform:uppercase;
      text-decoration:none;cursor:pointer;
      position:relative;overflow:hidden;
      transition:all 0.3s var(--ease);
      transform:skewX(-12deg);
      flex-shrink:0;
    }
    .pmin-cta>*{display:inline-flex;align-items:center;transform:skewX(12deg)}
    .pmin-cta::after{
      content:'';position:absolute;inset:0;
      background:linear-gradient(135deg, rgba(255,255,255,0.18), transparent 60%);
      opacity:0;transition:opacity 0.3s var(--ease);
    }
    .pmin-cta:hover{
      background:var(--red-bright);
      transform:skewX(-12deg) translateY(-2px);
      box-shadow:0 10px 36px var(--red-glow);
    }
    .pmin-cta:hover::after{opacity:1}

    /* ════════════════════════════════════════
       MODAL — enhanced calculator
    ════════════════════════════════════════ */
    .modal-overlay{
      position:fixed;inset:0;
      background:rgba(0,0,0,0.84);
      z-index:9000;
      display:flex;align-items:center;justify-content:center;
      padding:16px;
      opacity:0;pointer-events:none;
      transition:opacity 0.22s var(--ease);
      backdrop-filter:blur(6px);
    }
    .modal-overlay.open{opacity:1;pointer-events:all}

    .modal-card{
      background:#0e0c0c;
      border:1px solid rgba(193,39,45,0.38);
      border-radius:3px;
      width:100%;max-width:480px;
      position:relative;
      transform:translateY(16px) scale(0.97);
      transition:transform 0.28s var(--ease-out);
      overflow:hidden;
      max-height:92vh;overflow-y:auto;
      overscroll-behavior:contain;
    }
    .modal-overlay.open .modal-card{transform:translateY(0) scale(1)}
    .modal-card::before{
      content:'';display:block;height:3px;
      background:linear-gradient(to right, var(--red), var(--red-bright));
    }

    .modal-header{
      padding:22px 24px 0;
      display:flex;align-items:flex-start;justify-content:space-between;gap:12px;
    }
    .modal-trip-label{
      font-family:'Barlow Condensed',sans-serif;
      font-size:11px;font-weight:700;letter-spacing:0.22em;
      color:var(--red-bright);text-transform:uppercase;
      margin-bottom:5px;
    }
    .modal-trip-name{
      font-family:'Bebas Neue',sans-serif;
      font-size:34px;line-height:1;color:var(--white);
    }
    .modal-trip-sub{
      font-family:'Cormorant Garamond',serif;
      font-style:italic;
      font-size:17px;color:var(--gray-light);
      margin-top:7px;
      line-height:1.35;
      letter-spacing:0.005em;
    }
    .modal-close{
      width:32px;height:32px;
      border:1px solid rgba(255,255,255,0.12);
      border-radius:50%;
      background:transparent;color:var(--gray-mid);
      cursor:pointer;
      display:flex;align-items:center;justify-content:center;
      flex-shrink:0;transition:all 0.18s var(--ease);
    }
    .modal-close:hover{border-color:var(--red);color:var(--white)}
    .modal-close svg{width:14px;height:14px}

    .modal-divider{height:1px;background:var(--divider);margin:18px 24px}

    .modal-section-label{
      font-family:'Barlow Condensed',sans-serif;
      font-size:10.5px;font-weight:700;
      letter-spacing:0.22em;
      color:var(--gray-mid);
      text-transform:uppercase;
      padding:0 24px;margin-bottom:10px;
    }

    /* Toggle pill rows */
    .toggle-row{
      display:flex;gap:6px;
      padding:0 24px 18px;
    }
    .toggle-pill{
      flex:1;
      padding:10px 4px;
      background:rgba(255,255,255,0.04);
      border:1px solid rgba(255,255,255,0.10);
      border-radius:2px;
      color:var(--gray-light);
      font-family:'Barlow Condensed',sans-serif;
      font-size:13px;font-weight:600;
      letter-spacing:0.06em;
      cursor:pointer;
      transition:all 0.18s var(--ease);
      text-align:center;
      text-transform:uppercase;
      white-space:nowrap;
    }
    .toggle-pill:hover{
      border-color:rgba(193,39,45,0.5);
      color:var(--white);
      background:rgba(193,39,45,0.08);
    }
    .toggle-pill.active{
      border-color:var(--red);
      background:rgba(193,39,45,0.18);
      color:var(--white);
    }

    /* Group buttons stay as numbers */
    .group-btn{
      flex:1;padding:11px 4px;
      background:rgba(255,255,255,0.04);
      border:1px solid rgba(255,255,255,0.10);
      border-radius:2px;
      color:var(--gray-light);
      font-family:'Barlow Condensed',sans-serif;
      font-size:17px;font-weight:700;
      cursor:pointer;
      transition:all 0.15s var(--ease);
      text-align:center;
    }
    .group-btn:hover{
      border-color:rgba(193,39,45,0.5);
      color:var(--white);
      background:rgba(193,39,45,0.08);
    }
    .group-btn.active{
      border-color:var(--red);
      background:rgba(193,39,45,0.18);
      color:var(--white);
    }

    .modal-price-block{
      margin:6px 24px 0;
      background:rgba(193,39,45,0.07);
      border:1px solid rgba(193,39,45,0.22);
      border-radius:2px;
      padding:18px 20px;
      display:flex;align-items:center;justify-content:space-between;gap:12px;
    }
    .modal-price-eyebrow{
      font-family:'Barlow Condensed',sans-serif;
      font-size:10px;font-weight:700;letter-spacing:0.2em;
      color:var(--gray-mid);text-transform:uppercase;
      margin-bottom:4px;
    }
    .modal-price-amount{
      font-family:'Bebas Neue',sans-serif;
      font-size:54px;line-height:1;color:var(--white);
      transition:opacity 0.1s;
    }
    .modal-price-math{
      font-family:'Barlow',sans-serif;
      font-size:14px;
      font-weight:500;
      color:var(--gray-light);
      margin-top:8px;
      letter-spacing:0.015em;
      font-variant-numeric:tabular-nums;
      line-height:1.4;
    }
    .modal-price-math .fee{
      color:var(--gold);
      font-weight:700;
      letter-spacing:0.02em;
    }
    .modal-price-math em{
      font-style:normal;
      color:var(--gray-mid);
      font-weight:400;
      padding:0 4px;
    }
    .modal-price-per-person{
      font-size:12px;color:var(--gray-mid);margin-top:6px;
    }
    .modal-price-badge-text{
      font-family:'Barlow Condensed',sans-serif;
      font-size:10px;font-weight:700;letter-spacing:0.14em;
      text-transform:uppercase;color:var(--gold);
      background:rgba(201,168,76,0.10);
      border:1px solid rgba(201,168,76,0.28);
      border-radius:2px;
      padding:4px 9px;white-space:nowrap;text-align:center;line-height:1.5;
    }

    .modal-honest-note{
      margin:12px 24px 0;
      display:flex;align-items:flex-start;gap:8px;
      font-size:12px;color:var(--gray-mid);
      line-height:1.4;
    }
    .modal-honest-note svg{flex-shrink:0;color:var(--red);margin-top:1px}

    .modal-cta-row{
      padding:18px 24px 24px;
      display:flex;gap:14px;
    }
    .modal-book-btn{
      flex:1;
      display:inline-flex;align-items:center;justify-content:center;gap:8px;
      padding:14px 20px;
      background:var(--red);color:var(--white);
      font-family:'Barlow',sans-serif;
      font-weight:600;font-size:13.5px;
      letter-spacing:1.5px;text-transform:uppercase;
      text-decoration:none;cursor:pointer;
      transform:skewX(-12deg);
      position:relative;overflow:hidden;
      transition:background 0.25s var(--ease), transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
    }
