<script>
(function(){
  'use strict';

  /* Engine base prices (NET — pre-fee, Off Peak / Base = same baseline) */
  var BASE_NET = { 4: 425, 5: 550, 6: 700, 8: 950 };

  /* Per-person add-on fees (NET) by duration: [3rd, 4th, 5th] */
  var ADDONS_NET = {
    3:[50,50,100], 4:[50,50,100], 5:[62.5,62.5,100], 6:[75,75,125], 8:[100,100,175]
  };

  var FEE = 1.06;

  /* Season multipliers reflect new tier % (matching Pricing Engine v Final) */
  var SEASON_LABELS = {
    'off':      { label: 'Off Peak',  dates: 'Apr–May · Sep–Oct'                    },
    'standard': { label: 'Standard',  dates: 'Jun 1–12 · Aug 21–Sep 9 · Mon–Thu'    },
    'peak':     { label: 'Peak',      dates: 'Jul 1–Jul 25'                         },
    'holiday':  { label: 'Holiday',   dates: 'Memorial · July 4th · Labor Day'      }
  };

  var overlay      = document.getElementById('priceModal');
  var modalClose   = document.getElementById('modalClose');
  var modalDismiss = document.getElementById('modalDismiss');
  var modalName    = document.getElementById('modalTripName');
  var modalSub     = document.getElementById('modalTripSub');
  var modalPrice   = document.getElementById('modalPrice');
  var modalMath    = document.getElementById('modalMath');
  var modalPerP    = document.getElementById('modalPerPerson');

  var durBtns    = document.querySelectorAll('.toggle-pill[data-dur]');
  var seasonBtns = document.querySelectorAll('.toggle-pill[data-season]');
  var groupBtns  = document.querySelectorAll('.group-btn');

  var state = { duration: 5, season: 'off', mult: 1.00, guests: 1 };

  function calcSubtotal(){
    var base = BASE_NET[state.duration] * state.mult;
    var addons = ADDONS_NET[state.duration] || ADDONS_NET[4];
    if (state.guests >= 3) base += addons[0];
    if (state.guests >= 4) base += addons[1];
    if (state.guests >= 5) base += addons[2];
    return base;
  }

  function fmt(n){ return '$' + Math.round(n).toLocaleString('en-US'); }

  function setActive(buttons, matchKey, val){
    buttons.forEach(function(b){
      var on = b.getAttribute(matchKey) === String(val);
      b.classList.toggle('active', on);
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
  }

  function updateDisplay(){
    var subtotal = calcSubtotal();
    var fee      = subtotal * (FEE - 1);
    var total    = Math.round(subtotal * FEE);
    var per      = Math.round(total / state.guests);

    modalPrice.textContent = fmt(total);
    modalMath.innerHTML    = fmt(subtotal) + ' <em>+</em> <span class="fee">' + fmt(fee) + ' Provider Fee (6%)</span> <em>=</em> ' + fmt(total);
    modalPerP.textContent  = fmt(per) + ' per person';

    var seasonInfo = SEASON_LABELS[state.season];
    modalName.textContent = state.duration + '-Hour Trip';
    modalSub.textContent  = seasonInfo.label + ' · ' + seasonInfo.dates;
  }

  function openModal(dur){
    state.duration = dur;
    state.season = 'off';
    state.mult = 1.00;
    state.guests = 1;

    setActive(durBtns,    'data-dur',    dur);
    setActive(seasonBtns, 'data-season', 'off');
    setActive(groupBtns,  'data-guests', 1);

    updateDisplay();
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
    modalClose.focus();
  }

  function closeModal(){
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  /* Wire menu rows */
  document.querySelectorAll('.pmin-row').forEach(function(row){
    row.addEventListener('click', function(){
      openModal(parseInt(row.dataset.dur, 10));
    });
  });

  /* Duration toggle */
  durBtns.forEach(function(b){
    b.addEventListener('click', function(){
      state.duration = parseInt(b.dataset.dur, 10);
      setActive(durBtns, 'data-dur', state.duration);
      updateDisplay();
    });
  });

  /* Season toggle */
  seasonBtns.forEach(function(b){
    b.addEventListener('click', function(){
      state.season = b.dataset.season;
      state.mult   = parseFloat(b.dataset.mult);
      setActive(seasonBtns, 'data-season', state.season);
      updateDisplay();
    });
  });

  /* Group toggle */
  groupBtns.forEach(function(b){
    b.addEventListener('click', function(){
      state.guests = parseInt(b.dataset.guests, 10);
      setActive(groupBtns, 'data-guests', state.guests);
      updateDisplay();
    });
  });

  modalClose.addEventListener('click', closeModal);
  modalDismiss.addEventListener('click', closeModal);
  overlay.addEventListener('click', function(e){ if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape' && overlay.classList.contains('open')) closeModal();
  });

})();
</script>

<!-- IFRAME HEIGHT REPORTER — Wix Custom Embed auto-resize -->
<script>
(function(){
  if (window.parent === window) return;
  var lastH = 0;
  function report(){
    var h = Math.max(document.documentElement.scrollHeight, document.body ? document.body.scrollHeight : 0);
    if (h && h !== lastH) {
      lastH = h;
      try { window.parent.postMessage({ type: 'setHeight', height: h }, '*'); } catch(e){}
      try { window.parent.postMessage({ type: 'embed-size', height: h }, '*'); } catch(e){}
      try { window.parent.postMessage('height:' + h, '*'); } catch(e){}
    }
  }
  window.addEventListener('load', report);
  window.addEventListener('resize', report);
  if (window.ResizeObserver) { try { new ResizeObserver(report).observe(document.body); } catch(e){} }
  setInterval(report, 1500);
})();
</script>

