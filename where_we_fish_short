<style>
  /* ───────── DESIGN TOKENS ───────── */
  :root {
    --bx-black: #08080a;
    --bx-near-black: #0d0d11;
    --bx-graphite: #16171c;
    --bx-slate: #2a2d36;
    --bx-fog: #4a5560;
    --bx-bone: #c8c5bd;
    --bx-pearl: #e8e6e0;

    --bx-red: #e63946;
    --bx-red-deep: #c1272d;
    --bx-red-glow: rgba(230, 57, 70, 0.45);

    --bx-cyan: #1ce3d2;
    --bx-cyan-2: #0fb8b0;
    --bx-cyan-3: #086e7a;
    --bx-cyan-4: #04434f;
    --bx-cyan-5: #022933;

    --bx-tilt: 0deg;
    --bx-spin: 0deg;
    --bx-fade: 0;

    --font-display: 'Bebas Neue', 'Impact', sans-serif;
    --font-tactical: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    --font-body: 'Barlow', 'Helvetica Neue', sans-serif;
    --font-italic: 'Cormorant Garamond', Georgia, serif;
    --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-text-size-adjust: 100%; }

  body {
    background: var(--bx-black);
    color: var(--bx-pearl);
    font-family: var(--font-body);
    overscroll-behavior: none;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ───────── SECTION SHELL ───────── */
  .ops {
    position: relative;
    width: 100%;
    background: var(--bx-black);
    color: var(--bx-pearl);
    overflow: hidden;
    isolation: isolate;
  }

  .ops::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 50%, rgba(28, 227, 210, 0.04), transparent 70%),
      linear-gradient(180deg, var(--bx-black) 0%, #0a0a0e 50%, var(--bx-black) 100%);
    z-index: 0;
    pointer-events: none;
  }

  .ops::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(200, 197, 189, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200, 197, 189, 0.025) 1px, transparent 1px);
    background-size: 64px 64px;
    z-index: 0;
    pointer-events: none;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 45%, #000 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 45%, #000 30%, transparent 100%);
  }

  /* ───────── INTRO HEADER ───────── */
  .ops__intro {
    position: relative;
    z-index: 3;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(64px, 9vw, 120px) clamp(20px, 4vw, 56px) clamp(28px, 4vw, 48px);
    text-align: left;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-tactical);
    font-weight: 500;
    font-size: clamp(11px, 1.05vw, 13px);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--bx-red);
    margin: 0 0 22px;
  }
  .eyebrow::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--bx-red);
    box-shadow: 0 0 10px var(--bx-red-glow);
  }
  .eyebrow .live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--bx-red);
    box-shadow: 0 0 12px var(--bx-red-glow);
    animation: pulse-dot 2.4s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.8); }
  }

  .ops__headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(58px, 11vw, 168px);
    line-height: 0.86;
    letter-spacing: -0.01em;
    color: var(--bx-pearl);
    margin: 0;
    text-transform: uppercase;
  }
  .ops__headline em {
    font-family: var(--font-italic);
    font-style: italic;
    font-weight: 400;
    color: var(--bx-bone);
    letter-spacing: 0;
    font-size: 0.42em;
    display: block;
    margin-top: 0.35em;
    line-height: 1.05;
    text-transform: none;
  }

  .ops__bluf {
    font-family: var(--font-body);
    font-size: clamp(17px, 1.6vw, 21px);
    line-height: 1.55;
    color: var(--bx-bone);
    max-width: 64ch;
    margin: clamp(28px, 3vw, 40px) 0 0;
    font-weight: 300;
  }
  .ops__bluf strong {
    color: var(--bx-pearl);
    font-weight: 500;
  }

  /* ───────── MAP STAGE ───────── */
  .ops__theater {
    position: relative;
    z-index: 2;
    width: 100%;
    height: clamp(600px, 95vh, 980px);
    perspective: 2400px;
    perspective-origin: 50% 38%;
    margin: 0 auto;
  }

  .stage {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transform: rotateX(var(--bx-tilt)) rotateZ(var(--bx-spin));
    transform-origin: 50% 50%;
    will-change: transform;
  }

  .stage__plate {
    position: absolute;
    top: 50%;
    left: 50%;
    width: auto;
    height: 92%;
    aspect-ratio: 1000 / 1200;
    max-width: 88%;
    transform: translate(-50%, -50%);
    transform-style: preserve-3d;
  }

  /* ───────── HUD FRAME (lives outside the tilt — stays oriented) ───────── */
  .hud {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    font-family: var(--font-tactical);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bx-bone);
  }

  .hud__corner {
    position: absolute;
    width: 36px;
    height: 36px;
    border-color: var(--bx-red);
    opacity: 0.7;
  }
  .hud__corner--tl { top: 16px; left: 16px; border-top: 1px solid; border-left: 1px solid; }
  .hud__corner--tr { top: 16px; right: 16px; border-top: 1px solid; border-right: 1px solid; }
  .hud__corner--bl { bottom: 16px; left: 16px; border-bottom: 1px solid; border-left: 1px solid; }
  .hud__corner--br { bottom: 16px; right: 16px; border-bottom: 1px solid; border-right: 1px solid; }

  .hud__strip {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 10px;
    color: var(--bx-fog);
  }
  .hud__strip--top-left { top: 28px; left: 60px; }
  .hud__strip--top-right { top: 28px; right: 60px; }
  .hud__strip--bottom-left { bottom: 28px; left: 60px; }
  .hud__strip--bottom-right { bottom: 28px; right: 60px; }

  .hud__strip .key {
    color: var(--bx-fog);
  }
  .hud__strip .val {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--bx-pearl);
    letter-spacing: 0.04em;
    text-transform: none;
  }
  .hud__strip .val--accent {
    color: var(--bx-red);
  }

  .hud__divider {
    width: 1px;
    height: 12px;
    background: var(--bx-slate);
  }

  /* North arrow / compass */
  .hud__compass {
    position: absolute;
    bottom: 70px;
    right: 60px;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hud__compass svg { width: 100%; height: 100%; }
  .hud__compass .compass-rotor {
    transform-origin: center;
    animation: compass-drift 22s linear infinite;
  }
  @keyframes compass-drift {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Scale bar */
  .hud__scale {
    position: absolute;
    bottom: 70px;
    left: 60px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    color: var(--bx-bone);
    font-size: 10px;
  }
  .hud__scale-bar {
    display: flex;
    align-items: stretch;
    height: 6px;
    border: 1px solid var(--bx-fog);
  }
  .hud__scale-bar span {
    flex: 1;
    border-right: 1px solid var(--bx-fog);
  }
  .hud__scale-bar span:nth-child(odd) { background: var(--bx-fog); }
  .hud__scale-bar span:last-child { border-right: 0; }
  .hud__scale-labels {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--bx-fog);
  }

  /* ───────── 3D LAKE STACK ───────── */
  .lakes {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
  }

  /* Each depth layer is a full SVG shifted in Z. We stack 5 layers per lake set. */
  .lakes__layer {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    pointer-events: none;
  }
  .lakes__layer svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .lakes__layer--surface  { transform: translateZ(0px); }
  .lakes__layer--shallow  { transform: translateZ(-22px); }
  .lakes__layer--deep     { transform: translateZ(-55px); }
  .lakes__layer--abyss    { transform: translateZ(-100px); }

  /* Land plate — sits behind everything, gives mass */
  .land-plate {
    position: absolute;
    inset: 0;
    transform: translateZ(-130px);
  }
  .land-plate svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Lake outline visible at top — crisp */
  .lakes__layer--surface svg path {
    fill: var(--bx-cyan);
    fill-opacity: 0.10;
    stroke: var(--bx-cyan);
    stroke-width: 1.4;
    stroke-opacity: 0.95;
    filter: drop-shadow(0 0 6px rgba(28, 227, 210, 0.35));
  }

  .lakes__layer--shallow svg path {
    fill: var(--bx-cyan-2);
    fill-opacity: 0.20;
    stroke: var(--bx-cyan-2);
    stroke-width: 0.5;
    stroke-opacity: 0.35;
  }
  .lakes__layer--deep svg path {
    fill: var(--bx-cyan-3);
    fill-opacity: 0.50;
    stroke: var(--bx-cyan-3);
    stroke-width: 0.3;
    stroke-opacity: 0.25;
  }
  .lakes__layer--abyss svg path {
    fill: var(--bx-cyan-5);
    fill-opacity: 0.92;
    stroke: none;
  }

  /* Secondary lakes (Floyd / Melissa / Lizzie / Prairie) — surface only, atmospheric */
  .lakes__layer--surface svg path.secondary {
    fill-opacity: 0.05;
    stroke-opacity: 0.45;
    filter: none;
  }

  /* ───────── CALLOUT MARKERS ───────── */
  .markers {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    transform-style: preserve-3d;
  }

  .marker {
    position: absolute;
    transform-style: preserve-3d;
    pointer-events: auto;
    color: var(--bx-pearl);
  }

  .marker__pin {
    position: absolute;
    width: 14px;
    height: 14px;
    transform: translate(-50%, -50%) translateZ(8px);
  }
  .marker__pin::before,
  .marker__pin::after {
    content: "";
    position: absolute;
    inset: 0;
    border: 1px solid var(--bx-red);
    border-radius: 50%;
  }
  .marker__pin::after {
    inset: 4px;
    background: var(--bx-red);
    box-shadow: 0 0 12px var(--bx-red-glow);
  }
  .marker__pin .ring-pulse {
    position: absolute;
    inset: -8px;
    border: 1px solid var(--bx-red);
    border-radius: 50%;
    opacity: 0;
    animation: ring-pulse 3.2s ease-out infinite;
  }
  @keyframes ring-pulse {
    0% { transform: scale(0.5); opacity: 0.9; }
    80% { transform: scale(1.6); opacity: 0; }
    100% { opacity: 0; }
  }

  /* Tether line + label — counter-rotated to stay readable */
  .marker__label {
    position: absolute;
    transform: translateZ(40px);
    transform-origin: 0 50%;
    min-width: 188px;
    padding: 10px 14px;
    background: rgba(8, 8, 10, 0.78);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(28, 227, 210, 0.28);
    border-left: 2px solid var(--bx-red);
    font-family: var(--font-tactical);
  }
  .marker__label--right { left: 22px; top: -14px; }
  .marker__label--left  { right: 22px; top: -14px; border-left: 1px solid rgba(28, 227, 210, 0.28); border-right: 2px solid var(--bx-red); }
  /* --up-left: label sits ABOVE-LEFT of pin (used where the side-by-side spot is crowded) */
  .marker__label--up-left { right: 22px; bottom: 18px; border-left: 1px solid rgba(28, 227, 210, 0.28); border-right: 2px solid var(--bx-red); }
  .marker__label--right::before {
    content: "";
    position: absolute;
    left: -32px;
    top: 50%;
    width: 32px;
    height: 1px;
    background: linear-gradient(90deg, var(--bx-red), rgba(230, 57, 70, 0));
  }
  .marker__label--left::before {
    content: "";
    position: absolute;
    right: -32px;
    top: 50%;
    width: 32px;
    height: 1px;
    background: linear-gradient(270deg, var(--bx-red), rgba(230, 57, 70, 0));
  }
  .marker__label--up-left::before {
    /* tether anchored at label's bottom-right (closer to pin since label is above) */
    content: "";
    position: absolute;
    right: -22px;
    bottom: -1px;
    width: 22px;
    height: 1px;
    background: linear-gradient(270deg, var(--bx-red), rgba(230, 57, 70, 0));
  }
  .marker__name {
    display: block;
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1;
    letter-spacing: 0.06em;
    color: var(--bx-pearl);
    margin-bottom: 4px;
  }
  .marker__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0 12px;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--bx-bone);
    text-transform: uppercase;
  }
  .marker__meta .accent { color: var(--bx-cyan); }

  /* ───────── INTEL PANEL (below map) ───────── */
  .intel {
    position: relative;
    z-index: 3;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(48px, 6vw, 80px) clamp(20px, 4vw, 56px) clamp(80px, 10vw, 140px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 3vw, 48px);
  }

  .intel__col {
    border-top: 1px solid var(--bx-slate);
    padding-top: 28px;
  }

  .intel__lede {
    font-family: var(--font-italic);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(20px, 2.1vw, 28px);
    line-height: 1.3;
    color: var(--bx-bone);
  }
  .intel__lede strong {
    color: var(--bx-pearl);
    font-style: normal;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .intel__copy {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.65;
    color: var(--bx-bone);
    font-weight: 300;
  }
  .intel__copy strong {
    color: var(--bx-pearl);
    font-weight: 500;
  }

  .intel__sub {
    font-family: var(--font-tactical);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--bx-red);
    margin-bottom: 14px;
  }

  /* ───────── BENEATH-MAP CTA STRIP ───────── */
  .ops__cta {
    position: relative;
    z-index: 3;
    padding: clamp(40px, 5vw, 64px) clamp(20px, 4vw, 56px);
    border-top: 1px solid var(--bx-slate);
    border-bottom: 1px solid var(--bx-slate);
    background: linear-gradient(180deg, rgba(13, 13, 17, 0) 0%, rgba(13, 13, 17, 0.6) 100%);
  }
  .ops__cta-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .ops__cta-text {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 32px);
    letter-spacing: 0.02em;
    color: var(--bx-pearl);
  }
  .ops__cta-text em {
    font-family: var(--font-italic);
    font-style: italic;
    color: var(--bx-bone);
    font-size: 0.7em;
    display: block;
    letter-spacing: 0;
    margin-top: 4px;
  }
  .ops__cta-button {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 16px 28px;
    background: var(--bx-red);
    color: var(--bx-pearl);
    text-decoration: none;
    font-family: var(--font-tactical);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border: 1px solid var(--bx-red);
    transition: background 0.3s ease, transform 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .ops__cta-button:hover {
    background: var(--bx-red-deep);
    transform: translateY(-1px);
  }
  .ops__cta-button::after {
    content: "→";
    font-family: var(--font-mono);
    font-size: 16px;
    transition: transform 0.3s ease;
  }
  .ops__cta-button:hover::after { transform: translateX(4px); }

  /* ───────── RESPONSIVE ───────── */
  @media (max-width: 900px) {
    .ops__theater {
      perspective: 1600px;
      height: clamp(480px, 75vh, 700px);
    }
    .stage__plate { height: 94%; max-width: 96%; }
    .hud__strip--top-left { top: 22px; left: 50px; }
    .hud__strip--top-right { display: none; }
    .hud__strip--bottom-right { display: none; }
    .hud__compass { width: 44px; height: 44px; bottom: 60px; right: 50px; }
    .hud__scale { left: 50px; bottom: 60px; }
    .marker__label { min-width: 140px; padding: 8px 10px; }
    .marker__label--left { right: auto; left: 22px; top: 18px; border-right: 1px solid rgba(28, 227, 210, 0.28); border-left: 2px solid var(--bx-red); }
    .marker__label--left::before { right: auto; left: -22px; background: linear-gradient(90deg, var(--bx-red), rgba(230, 57, 70, 0)); width: 22px; }
    .marker__label--right::before { left: -22px; width: 22px; }
    /* --up-left: keep above-left on mobile too — sits up and slightly left of pin */
    .marker__label--up-left { right: 22px; bottom: 14px; }
    .marker__label--up-left::before { right: -22px; width: 22px; }
    .marker__name { font-size: 14px; }
    .marker__meta { font-size: 9px; }
    .intel { grid-template-columns: 1fr; }
  }

  @media (max-width: 560px) {
