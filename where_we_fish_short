<script>
(function() {
  'use strict';

  const section  = document.getElementById('ops-theater');
  const theater  = document.getElementById('theater');
  const stage    = document.getElementById('stage');

  if (!section || !theater || !stage) return;

  // Respect reduced motion
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reducedMotion) {
    stage.style.setProperty('--bx-tilt', '8deg');
    stage.style.setProperty('--bx-spin', '0deg');
    return;
  }

  // ── Tunables ──
  // Tilt: how much the map leans back to reveal depth. Tuned for premium feel — substantial but not extreme.
  const MAX_TILT_DESKTOP = 30;   // degrees — increased per Brady, more dramatic depth reveal
  const MAX_TILT_MOBILE  = 19;   // degrees
  // Spin: clockwise rotation. Brady spec — "no more than 1/8 inch displacement" → barely perceptible.
  const MAX_SPIN_DESKTOP = 2.6;  // degrees
  const MAX_SPIN_MOBILE  = 1.8;  // degrees
  // Lerp factor: lower = smoother/heavier, higher = more responsive. 0.10 is the Apple sweet spot.
  const LERP = 0.14;  // bumped per Brady — faster response, still buttery

  const isMobile = () => window.matchMedia('(max-width: 900px)').matches;

  let scrollTarget  = 0;
  let scrollCurrent = 0;
  let inView        = false;
  let rafId         = null;

  // Compute scroll progress: 0 when section is fully below viewport, 1 when fully above.
  // Apex at ~50% through the section's travel.
  const computeProgress = () => {
    const rect = theater.getBoundingClientRect();
    const vh = window.innerHeight || document.documentElement.clientHeight;
    // Travel range: from "section bottom touches viewport bottom" to "section top exits viewport top"
    const total = vh + rect.height;
    const traveled = vh - rect.top;
    const raw = traveled / total;
    return Math.max(0, Math.min(1, raw));
  };

  const tick = () => {
    // Lerp toward target — buttery
    scrollCurrent += (scrollTarget - scrollCurrent) * LERP;

    const tiltMax = isMobile() ? MAX_TILT_MOBILE : MAX_TILT_DESKTOP;
    const spinMax = isMobile() ? MAX_SPIN_MOBILE : MAX_SPIN_DESKTOP;

    // Easing: ease-in-out so the tilt feels weighted, not linear
    const eased = scrollCurrent < 0.5
      ? 2 * scrollCurrent * scrollCurrent
      : 1 - Math.pow(-2 * scrollCurrent + 2, 2) / 2;

    const tilt = eased * tiltMax;
    const spin = eased * spinMax;

    stage.style.transform = `rotateX(${tilt.toFixed(3)}deg) rotateZ(${spin.toFixed(3)}deg)`;

    // Continue animating if delta is meaningful, otherwise idle
    if (Math.abs(scrollTarget - scrollCurrent) > 0.0005) {
      rafId = requestAnimationFrame(tick);
    } else {
      rafId = null;
      stage.style.willChange = 'auto';
    }
  };

  const onScroll = () => {
    if (!inView) return;
    scrollTarget = computeProgress();
    if (rafId === null) {
      stage.style.willChange = 'transform';
      rafId = requestAnimationFrame(tick);
    }
  };

  // IntersectionObserver — only animate when section is near viewport
  const io = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      inView = entry.isIntersecting;
      if (inView) {
        // Prime values on entry
        scrollTarget = computeProgress();
        if (rafId === null) {
          stage.style.willChange = 'transform';
          rafId = requestAnimationFrame(tick);
        }
      }
    });
  }, { rootMargin: '20% 0px 20% 0px', threshold: 0 });

  io.observe(theater);

  // Single passive scroll listener
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll, { passive: true });

  // Prime on load
  scrollTarget = computeProgress();
  scrollCurrent = scrollTarget * 0.4; // start partially settled to avoid initial snap
  rafId = requestAnimationFrame(tick);

  // ── Iframe height reporter (Wix Custom Embed) ──
  const reportHeight = () => {
    if (window.parent && window.parent !== window) {
      try {
        window.parent.postMessage({
          type: 'baxstar:height',
          section: 'ground-truth',
          height: document.body.scrollHeight
        }, '*');
      } catch (e) { /* cross-origin — ignore */ }
    }
  };
  window.addEventListener('load', reportHeight);
  window.addEventListener('resize', reportHeight);
  // Re-report after fonts load (height shifts)
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(reportHeight);
  }
})();
</script>

