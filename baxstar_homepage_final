  (function initGallery(){
    var track   = document.getElementById('galleryTrack');
    var btnPrev = document.getElementById('galPrev');
    var btnNext = document.getElementById('galNext');
    var fill    = document.getElementById('galFill');
    var label   = document.getElementById('galCounter');
    var lb      = document.getElementById('lightbox');
    var lbImg   = document.getElementById('lbImg');
    var lbClose = document.getElementById('lbClose');
    var lbPrev  = document.getElementById('lbPrev');
    var lbNext  = document.getElementById('lbNext');
    if (!track) return;

    var total = IMAGES.length;
    var currentIdx = 0;
    var lbIdx = 0;

    IMAGES.forEach(function(img, i){
      var card = document.createElement('div');
      card.className = 'gallery__card';
      card.setAttribute('role', 'listitem');
      card.setAttribute('tabindex', '0');
      card.setAttribute('aria-label', img.alt);
      card.innerHTML =
        '<img src="' + img.src + '" alt="' + img.alt + '" loading="' + (i < 3 ? 'eager' : 'lazy') + '">' +
        '<div class="gallery__card-bar"></div>' +
        '<div class="gallery__card-zoom" aria-hidden="true">' +
          '<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">' +
            '<polyline points="8 1 12 1 12 5"/><polyline points="5 12 1 12 1 8"/>' +
            '<line x1="12" y1="1" x2="7.5" y2="5.5"/><line x1="1" y1="13" x2="5.5" y2="7.5"/>' +
          '</svg>' +
        '</div>';
      card.addEventListener('click', function(){ openLb(i); });
      card.addEventListener('keydown', function(e){
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLb(i); }
      });
      track.appendChild(card);
    });

    function getCardW(){
      var c = track.querySelector('.gallery__card');
      if (!c) return 280;
      return c.offsetWidth + parseInt(getComputedStyle(track).gap || 10);
    }
    function scrollTo(idx){
      currentIdx = Math.max(0, Math.min(idx, total - 1));
      track.scrollTo({ left: currentIdx * getCardW(), behavior: 'smooth' });
      updateUI();
    }
    function updateUI(){
      var pct = total <= 1 ? 100 : (currentIdx / (total - 1)) * 100;
      fill.style.width = Math.max(6, pct) + '%';
      label.innerHTML = '<strong>' + (currentIdx + 1) + '</strong> of ' + total;
      btnPrev.disabled = currentIdx === 0;
      btnNext.disabled = currentIdx === total - 1;
    }

    btnPrev.addEventListener('click', function(){ scrollTo(currentIdx - 1); });
    btnNext.addEventListener('click', function(){ scrollTo(currentIdx + 1); });

    var scrollTimer;
    track.addEventListener('scroll', function(){
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function(){
        currentIdx = Math.round(track.scrollLeft / getCardW());
        updateUI();
      }, 80);
    });

    var drag = false, startX, startScroll;
    track.addEventListener('mousedown', function(e){
      drag = true; startX = e.pageX; startScroll = track.scrollLeft;
      track.style.cursor = 'grabbing';
    });
    document.addEventListener('mousemove', function(e){
      if (!drag) return;
      track.scrollLeft = startScroll - (e.pageX - startX);
    });
    document.addEventListener('mouseup', function(){
      drag = false; track.style.cursor = 'grab';
    });

    document.addEventListener('keydown', function(e){
      if (lb.classList.contains('open')) return;
      var modal = document.getElementById('pminModal');
      if (modal && modal.classList.contains('open')) return;
      if (e.key === 'ArrowLeft')  scrollTo(currentIdx - 1);
      if (e.key === 'ArrowRight') scrollTo(currentIdx + 1);
    });

    function openLb(idx){
      lbIdx = idx;
      lbImg.src = IMAGES[idx].src;
      lbImg.alt = IMAGES[idx].alt;
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
      updateLbNav();
    }
    function closeLb(){
      lb.classList.remove('open');
      document.body.style.overflow = '';
      setTimeout(function(){ lbImg.src = ''; }, 400);
    }
    function updateLbNav(){
      lbPrev.style.display = lbIdx === 0 ? 'none' : 'flex';
      lbNext.style.display = lbIdx === total - 1 ? 'none' : 'flex';
    }

    lbClose.addEventListener('click', closeLb);
    lb.addEventListener('click', function(e){ if (e.target === lb) closeLb(); });
    lbPrev.addEventListener('click', function(){ openLb(lbIdx - 1); });
    lbNext.addEventListener('click', function(){ openLb(lbIdx + 1); });
    document.addEventListener('keydown', function(e){
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape')     closeLb();
      if (e.key === 'ArrowLeft' && lbIdx > 0)            openLb(lbIdx - 1);
      if (e.key === 'ArrowRight' && lbIdx < total - 1)   openLb(lbIdx + 1);
    });

    var lbTouchX = 0;
    lb.addEventListener('touchstart', function(e){ lbTouchX = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', function(e){
      var d = lbTouchX - e.changedTouches[0].clientX;
      if (Math.abs(d) > 40) {
        if (d > 0 && lbIdx < total - 1) openLb(lbIdx + 1);
        else if (d < 0 && lbIdx > 0) openLb(lbIdx - 1);
      }
    }, { passive: true });

    updateUI();
  })();


  /* ═══════════════════════════════════════════════════════════
