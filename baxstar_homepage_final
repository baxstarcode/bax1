/* ── RESET ──────────────────────────────────────────────────────── */
*,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
html, body { width:100%; overflow-x:hidden; }
body {
  background: var(--black);
  color: var(--cream);
  font-family: var(--font-body);
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  overscroll-behavior: none;
  line-height: 1.55;
}
img { display:block; max-width:100%; }
a { color:inherit; text-decoration:none; }
button { font:inherit; background:none; border:none; color:inherit; cursor:pointer; }

/* ── DESIGN TOKENS ──────────────────────────────────────────────── */
:root {
  /* Color */
  --black:        #08080a;
  --charcoal:     #0d0d10;
  --dark:         #18181c;
  --mid-dark:     #222228;
  --red:          #c1272d;
  --red-bright:   #e63946;
  --red-deep:     #8b1a1f;
  --red-glow:     rgba(193,39,45,0.55);
  --cream:        #f0ece4;
  --warm-white:   #faf8f4;
  --white:        #ffffff;
  --w-90:         rgba(255,255,255,0.90);
  --w-70:         rgba(255,255,255,0.70);
  --w-60:         rgba(255,255,255,0.60);
  --w-50:         rgba(255,255,255,0.50);
  --w-30:         rgba(255,255,255,0.30);
  --w-14:         rgba(255,255,255,0.14);
  --w-08:         rgba(255,255,255,0.08);
  --w-06:         rgba(255,255,255,0.06);
  --gold:         #c9a84c;
  --gold-dim:     #9a7d3a;
  --gray-light:   #d4d0c9;
  --gray-mid:     #8f8f9a;
  --slate:        #6b6b78;
  --light-slate:  #9a9aaa;
  --divider:      rgba(255,255,255,0.08);
  --divider-strong: rgba(255,255,255,0.14);

  /* Typography */
  --font-display: 'Bebas Neue', sans-serif;
  --font-body:    'Barlow', sans-serif;
  --font-condensed: 'Barlow Condensed', sans-serif;
  --font-accent:  'Cormorant Garamond', serif;

  /* Layout — equidistant section rhythm */
  --section-pad-y: clamp(80px, 9vw, 130px);
  --section-pad-x: clamp(20px, 4vw, 60px);
  --container-max: 1320px;

  /* Motion */
  --ease:     cubic-bezier(0.4, 0, 0.2, 1);
  --ease-out: cubic-bezier(0.2, 0.8, 0.2, 1);
}

/* ── UTILITIES ──────────────────────────────────────────────────── */
.sr-only {
  position:absolute; width:1px; height:1px; padding:0; margin:-1px;
  overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0;
}
.bx-container { max-width: var(--container-max); margin:0 auto; padding: 0 var(--section-pad-x); }

/* Section base — equidistant spacing across the page */
.bx-section { padding: var(--section-pad-y) 0; position:relative; background: var(--black); }
.bx-section--narrow { padding: clamp(56px, 6vw, 84px) 0; }
.bx-section--charcoal { background: var(--charcoal); }

/* Shared section label/title pattern */
.bx-eyebrow {
  font-family: var(--font-condensed);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--red-bright);
  display: inline-flex;
  align-items: center;
  gap: 14px;
}
.bx-eyebrow::before {
  content:''; width:24px; height:1px; background:var(--red);
}
.bx-eyebrow--center { justify-content: center; }
.bx-eyebrow--center::after {
  content:''; width:24px; height:1px; background:var(--red);
}

.bx-title {
  font-family: var(--font-display);
  font-size: clamp(38px, 5.5vw, 64px);
  line-height: 0.95;
  letter-spacing: 0.012em;
  color: var(--warm-white);
  text-transform: uppercase;
  margin: 18px 0 22px;
}
.bx-title .accent { color: var(--red-bright); }

/* Shared CTA buttons — slant style */
.bx-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 36px;
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 13px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: all 0.3s var(--ease);
  transform: skewX(-12deg);
  white-space: nowrap;
}
.bx-btn > * { display: inline-flex; align-items: center; transform: skewX(12deg); }
.bx-btn svg { width: 14px; height: 14px; fill: none; stroke: currentColor; stroke-width: 2.2; flex-shrink: 0; }

.bx-btn--primary { background: var(--red); color: var(--white); }
.bx-btn--primary::after {
  content:''; position:absolute; inset:0;
  background: linear-gradient(120deg, rgba(255,255,255,0.18), transparent 60%);
  opacity: 0; transition: opacity 0.32s var(--ease);
}
.bx-btn--primary:hover { background: var(--red-bright); transform: skewX(-12deg) translateY(-2px); box-shadow: 0 10px 30px var(--red-glow); }
.bx-btn--primary:hover::after { opacity: 1; }

.bx-btn--ghost {
  background: transparent;
  color: var(--cream);
  border: 1px solid var(--w-30);
}
.bx-btn--ghost:hover {
  border-color: var(--cream);
  background: rgba(240,236,228,0.06);
  transform: skewX(-12deg) translateY(-2px);
}

/* ── SCROLL REVEAL — Apple-quality, compositor-thread ─────────────── */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.75s var(--ease), transform 0.75s var(--ease);
  will-change: transform, opacity;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
  will-change: auto;
}
@media (prefers-reduced-motion: reduce) {
  .reveal { opacity:1; transform:none; transition:none; will-change:auto; }
}

/* ════════════════════════════════════════════════════════════════
   SECTION 1 — HERO (cinematic, full viewport)
══════════════════════════════════════════════════════════════════ */
.hero {
  position: relative;
  width: 100%;
  min-height: 100vh;
  min-height: 100svh;
  overflow: hidden;
  display: flex;
  align-items: stretch;
  background: var(--black);
}

/* LCP background image — paints immediately */
.hero__bg-img {
  position: absolute; inset: 0; z-index: 1;
  background-image: url('https://static.wixstatic.com/media/a30e59_3f9317aa58dc475e9684360413f33ba8~mv2.jpg');
  background-size: cover;
  background-position: center center;
  will-change: transform;
}

/* Cinemagraph video — fades in after LCP */
.hero__video {
  position: absolute; inset: 0; z-index: 2;
  opacity: 0;
  transition: opacity 1.4s var(--ease);
  pointer-events: none;
}
.hero__video video {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center center;
}
.hero__video.is-ready { opacity: 1; }

/* Atmosphere stack */
.hero__veil {
  position: absolute; inset: 0; z-index: 3;
  background: linear-gradient(105deg,
    rgba(8,8,10,0.93) 0%,
    rgba(8,8,10,0.78) 35%,
    rgba(8,8,10,0.35) 62%,
    rgba(8,8,10,0.08) 100%);
}
.hero__grain {
  position: absolute; inset: 0; z-index: 4;
  opacity: 0.036;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px 180px;
  pointer-events: none;
}
.hero__vignette {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 220px; z-index: 4;
  background: linear-gradient(to bottom, transparent 0%, rgba(8,8,10,0.95) 100%);
  pointer-events: none;
}
.hero__edge {
  position: absolute; top: 0; left: 0; bottom: 0;
  width: 3px; z-index: 5;
  background: linear-gradient(180deg, transparent 0%, var(--red) 25%, var(--red) 75%, transparent 100%);
  pointer-events: none;
}
.hero__scan {
  position: absolute; left: 0; right: 0;
  height: 1.5px; z-index: 5;
  background: linear-gradient(90deg, transparent 0%, transparent 10%, rgba(193,39,45,0.65) 50%, transparent 90%, transparent 100%);
  animation: hero-scan 8s linear infinite;
  pointer-events: none;
}
@keyframes hero-scan {
  0%   { top:-2px;  opacity:0;   }
  3%   { opacity:0.8; }
  97%  { opacity:0.8; }
  100% { top:100%;  opacity:0;   }
}

/* Corner brackets */
.hero__bracket {
  position: absolute;
  width: 48px; height: 48px;
  z-index: 8;
  pointer-events: none;
  opacity: 0;
  animation: hero-bracket-in 0.6s var(--ease) forwards;
}
.hero__bracket--tl { top: 24px; left: 24px;  border-top: 1.5px solid var(--red); border-left: 1.5px solid var(--red); animation-delay: 0.30s; }
.hero__bracket--tr { top: 24px; right: 24px; border-top: 1.5px solid var(--red); border-right: 1.5px solid var(--red); animation-delay: 0.45s; }
.hero__bracket--bl { bottom: 24px; left: 24px;  border-bottom: 1.5px solid var(--red); border-left: 1.5px solid var(--red); animation-delay: 0.60s; }
.hero__bracket--br { bottom: 24px; right: 24px; border-bottom: 1.5px solid var(--red); border-right: 1.5px solid var(--red); animation-delay: 0.75s; }
@keyframes hero-bracket-in { to { opacity: 1; } }

.hero__bracket::after {
  content: ''; position: absolute;
  width: 5px; height: 5px;
  background: var(--red); border-radius: 50%;
  box-shadow: 0 0 8px 3px var(--red-glow);
  animation: hero-pulse 3s ease-in-out infinite;
}
.hero__bracket--tl::after { top: -2.5px; left: -2.5px; }
.hero__bracket--tr::after { top: -2.5px; right: -2.5px; }
.hero__bracket--bl::after { bottom: -2.5px; left: -2.5px; }
.hero__bracket--br::after { bottom: -2.5px; right: -2.5px; }
@keyframes hero-pulse {
  0%, 100% { opacity:1; transform:scale(1);    }
  50%      { opacity:0.15; transform:scale(0.65); }
}

/* HUD coordinates */
.hero__hud {
  position: absolute;
  font-family: var(--font-condensed);
  font-size: 8.5px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.18);
  z-index: 8;
  pointer-events: none;
  opacity: 0;
  animation: hero-fade-up 0.7s ease forwards;
}
.hero__hud--tl { top: 36px;    left: 84px;  animation-delay: 0.90s; }
.hero__hud--tr { top: 36px;    right: 84px; text-align: right; animation-delay: 1.00s; }
.hero__hud--bl { bottom: 36px; left: 84px;  animation-delay: 1.10s; }
.hero__hud--br { bottom: 36px; right: 84px; text-align: right; animation-delay: 1.20s; }

/* Content */
.hero__inner {
