  gap: 12px;
  font-family: var(--font-condensed);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.42em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 20px;
  opacity: 0;
  animation: hero-fade-up 0.7s ease forwards 0.20s;
}
.hero__eyebrow::before {
  content: ''; display: block;
  width: 22px; height: 1px;
  background: var(--red);
  flex-shrink: 0;
}
.hero__headline {
  font-family: var(--font-display);
  font-size: clamp(58px, 7.5vw, 108px);
  line-height: 0.9;
  letter-spacing: 0.01em;
  color: var(--white);
  opacity: 0;
  animation: hero-fade-up 0.8s var(--ease-out) forwards 0.35s;
}
.hero__headline .ghost {
  color: transparent;
  -webkit-text-stroke: 1.5px rgba(255,255,255,0.22);
  display: block;
}
.hero__headline .accent {
  color: var(--red);
  display: block;
}
.hero__divider {
  display: flex; align-items: center;
  gap: 14px;
  margin: 22px 0 26px;
  opacity: 0;
  animation: hero-fade-up 0.6s ease forwards 0.55s;
}
.hero__divider-line {
  height: 1px; width: 60px;
  background: linear-gradient(90deg, var(--red), transparent);
}
.hero__divider-dot {
  width: 5px; height: 5px;
  background: var(--red);
  transform: rotate(45deg);
  box-shadow: 0 0 8px 2px var(--red-glow);
}
.hero__body {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: clamp(14px, 1.5vw, 17px);
  line-height: 1.75;
  color: var(--w-60);
  max-width: 480px;
  margin-bottom: 40px;
  letter-spacing: 0.025em;
  opacity: 0;
  animation: hero-fade-up 0.7s ease forwards 0.65s;
}
.hero__cta {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 52px;
  opacity: 0;
  animation: hero-fade-up 0.7s ease forwards 0.80s;
}
.hero__cta .bx-btn { padding: 16px 38px; }

.hero__stats {
  display: flex;
  align-items: center;
  opacity: 0;
  animation: hero-fade-up 0.7s ease forwards 0.95s;
}
.hero__stat {
  display: flex;
  flex-direction: column;
  padding: 0 26px;
  position: relative;
}
.hero__stat:first-child { padding-left: 0; }
.hero__stat + .hero__stat::before {
  content: ''; position: absolute;
  left: 0; top: 10%; bottom: 10%;
  width: 1px;
  background: var(--w-14);
}
.hero__stat__num {
  font-family: var(--font-condensed);
  font-weight: 800;
  font-size: clamp(28px, 3.2vw, 42px);
  line-height: 1;
  color: var(--white);
}
.hero__stat__num em { color: var(--red); font-style: normal; }
.hero__stat__lbl {
  font-family: var(--font-body);
  font-size: 9px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  margin-top: 5px;
}

@keyframes hero-fade-up {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Hero — mobile */
@media (max-width: 768px) {
  .hero__bg-img {
    background-image: url('https://static.wixstatic.com/media/a30e59_6c68ef96330040e9b9fc7a4524e28e3a~mv2.jpeg');
    background-position: 25% 12%;
  }
  .hero__video video { object-position: 25% 12%; }
  .hero__veil {
    background: linear-gradient(180deg,
      rgba(8,8,10,0.25) 0%,
      rgba(8,8,10,0.38) 38%,
      rgba(8,8,10,0.88) 68%,
      rgba(8,8,10,0.97) 100%);
  }
  .hero__inner {
    width: 100%;
    max-width: 100%;
    padding: 80px 24px 48px;
    justify-content: flex-end;
    min-height: 100svh;
    align-items: center;
    text-align: center;
  }
  .hero__eyebrow { display: none; }
  .hero__body { max-width: 100%; }
  .hero__cta { justify-content: center; gap: 12px; margin-bottom: 36px; }
  .hero__cta .bx-btn { font-size: 11px; padding: 14px 28px; letter-spacing: 0.16em; }
  .hero__stats { justify-content: center; }
  .hero__stat { padding: 0 18px; }
  .hero__hud { display: none; }
  .hero__edge { display: none; }
  .hero__scan { display: none; }
  .hero__bracket { width: 32px; height: 32px; }
  .hero__bracket--tl, .hero__bracket--tr { top: 14px; }
  .hero__bracket--bl, .hero__bracket--br { bottom: 14px; }
  .hero__bracket--tl, .hero__bracket--bl { left: 14px; }
  .hero__bracket--tr, .hero__bracket--br { right: 14px; }
}
@media (max-width: 400px) {
  .hero__headline { font-size: clamp(46px, 13vw, 60px); }
  .hero__stats { flex-wrap: wrap; gap: 8px; justify-content: center; }
  .hero__stat { padding: 0 14px; }
}

/* ════════════════════════════════════════════════════════════════
   SECTION 2 — PROOF BAR (scrolling ticker)
══════════════════════════════════════════════════════════════════ */
.proof-bar {
  background: var(--red);
  padding: 14px 0;
  overflow: hidden;
  position: relative;
}
.proof-bar__track {
  display: flex;
  gap: 60px;
  animation: ticker 38s linear infinite;
  white-space: nowrap;
  width: max-content;
  list-style: none;
  margin: 0; padding: 0;
}
.proof-bar__item {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 13px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--white);
  display: flex;
  align-items: center;
  gap: 16px;
  flex-shrink: 0;
}
.proof-bar__item::after {
  content: '◆';
  font-size: 6px;
  opacity: 0.55;
}
@keyframes ticker {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.proof-bar:hover .proof-bar__track,
.proof-bar:focus-within .proof-bar__track { animation-play-state: paused; }
@media (prefers-reduced-motion: reduce) {
  .proof-bar__track { animation: none; }
}

/* ════════════════════════════════════════════════════════════════
   SECTION 3 — PRESS STRIP ("As Featured In")
══════════════════════════════════════════════════════════════════ */
.press {
  padding: clamp(50px, 6vw, 70px) 0;
  background: var(--charcoal);
  border-top: 1px solid var(--w-06);
  border-bottom: 1px solid var(--w-06);
}
.press__inner {
  display: flex;
  align-items: center;
  gap: clamp(28px, 4vw, 60px);
  flex-wrap: wrap;
  justify-content: center;
}
.press__label {
  font-family: var(--font-body);
  font-weight: 500;
  font-size: 10px;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--slate);
  white-space: nowrap;
}
.press__divider {
  width: 1px; height: 36px;
  background: var(--w-08);
  flex-shrink: 0;
}
.press__logos {
  display: flex;
  align-items: center;
  gap: clamp(28px, 4vw, 60px);
  flex-wrap: wrap;
  justify-content: center;
}
.press__logo {
  font-family: var(--font-body);
  font-weight: 700;
  font-size: clamp(13px, 1.6vw, 17px);
  color: rgba(240,236,228,0.20);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  transition: color 0.4s var(--ease);
  white-space: nowrap;
}
.press__logo:hover { color: rgba(240,236,228,0.55); }
@media (max-width: 640px) {
  .press__divider { display: none; }
}

/* ════════════════════════════════════════════════════════════════
   SECTION 4 — HOW IT WORKS (3-step process)
══════════════════════════════════════════════════════════════════ */
.process { background: var(--black); }
.process__layout {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: clamp(40px, 6vw, 100px);
  align-items: start;
}
.process__left {
  position: sticky;
  top: clamp(80px, 10vh, 120px);
}
.process__intro {
  font-size: 15px;
  line-height: 1.8;
  color: var(--slate);
  font-weight: 300;
  margin-top: 8px;
}
.process__steps {
  list-style: none;
  display: flex;
  flex-direction: column;
}
.process__step {
  padding: 36px 0;
  border-bottom: 1px solid var(--w-06);
  display: grid;
  grid-template-columns: 60px 1fr;
  gap: 24px;
  align-items: start;
  transition: background 0.3s var(--ease);
}
.process__step:first-child { border-top: 1px solid var(--w-06); }
.process__step-num {
  font-family: var(--font-display);
  font-size: 42px;
  color: rgba(193,39,45,0.25);
  line-height: 1;
  padding-top: 2px;
  transition: color 0.4s var(--ease);
}
.process__step:hover .process__step-num { color: var(--red); }
.process__step-title {
  font-family: var(--font-display);
  font-size: clamp(22px, 2.4vw, 28px);
  text-transform: uppercase;
  letter-spacing: 0.025em;
  color: var(--warm-white);
  margin-bottom: 12px;
  line-height: 1.1;
}
.process__step-text {
  font-size: 15px;
  line-height: 1.78;
  color: var(--slate);
  font-weight: 300;
  max-width: 480px;
}
@media (max-width: 1024px) {
  .process__layout { grid-template-columns: 1fr; gap: 48px; }
  .process__left { position: static; }
}

/* ════════════════════════════════════════════════════════════════
   SECTION 5 — PRICING MINIMAL (the only pricing on homepage)
   Full table moves to /pricing — homepage gets the editorial menu
══════════════════════════════════════════════════════════════════ */
.pricing-min {
  position: relative;
  background: var(--black);
  overflow: hidden;
  /* Keeping the section padding rhythm — no extra "black bar" below */
}
.pricing-min__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  background:
    radial-gradient(ellipse at 92% 28%, rgba(122,24,8,0.40) 0%, rgba(74,13,5,0.18) 35%, transparent 65%),
    radial-gradient(ellipse at 5% 85%, rgba(122,24,8,0.18) 0%, transparent 55%),
    var(--black);
}
.pricing-min__bg::after {
  content: '';
  position: absolute; inset: 0;
  opacity: 0.035;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px 200px;
}
.pricing-min__inner {
  position: relative;
  z-index: 2;
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 var(--section-pad-x);
}

/* Header */
.pmin-header {
  text-align: center;
  max-width: 680px;
  margin: 0 auto clamp(56px, 7vw, 88px);
}
.pmin-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  font-family: var(--font-condensed);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--red-bright);
  margin-bottom: 20px;
}
.pmin-eyebrow::before, .pmin-eyebrow::after {
  content: ''; width: 24px; height: 1px; background: var(--red);
}
.pmin-headline {
  font-family: var(--font-display);
  font-size: clamp(56px, 8vw, 96px);
  line-height: 0.92;
  letter-spacing: 0.012em;
  color: var(--white);
  margin-bottom: 22px;
  position: relative;
}
.pmin-headline .accent { color: var(--red); }
.pmin-italic {
  display: block;
  font-family: var(--font-accent);
  font-style: italic;
  font-weight: 400;
  font-size: 0.34em;
  line-height: 1;
  letter-spacing: 0.012em;
  color: var(--gold);
  margin-bottom: -0.05em;
}
.pmin-subhead {
  font-size: clamp(15px, 1.5vw, 17px);
  font-weight: 300;
  line-height: 1.7;
  color: var(--gray-light);
  max-width: 520px;
  margin: 0 auto;
  letter-spacing: 0.005em;
}

/* Menu rows */
.pmin-menu {
  list-style: none;
  border-top: 1px solid var(--divider-strong);
  margin-bottom: 24px;
}
.pmin-row {
  position: relative;
  width: 100%;
  display: grid;
  grid-template-columns: auto 1fr auto auto;
  align-items: center;
  gap: clamp(20px, 3vw, 40px);
  padding: clamp(28px, 3.4vw, 38px) clamp(8px, 2vw, 20px) clamp(22px, 3vw, 32px);
  border-bottom: 1px solid var(--divider-strong);
  cursor: pointer;
  background: transparent;
  text-align: left;
  transition: background 0.32s var(--ease), padding-left 0.32s var(--ease-out);
}
.pmin-row::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 0;
  background: linear-gradient(90deg, var(--red) 0%, transparent 100%);
  opacity: 0;
  transition: width 0.42s var(--ease-out), opacity 0.3s var(--ease);
}
.pmin-row:hover {
  background: rgba(193,39,45,0.04);
  padding-left: clamp(22px, 3.5vw, 40px);
}
.pmin-row:hover::before { width: 3px; opacity: 1; }

.pmin-row__num {
  font-family: var(--font-condensed);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.28em;
  color: var(--gray-mid);
  flex-shrink: 0;
  min-width: 42px;
  transition: color 0.3s var(--ease);
}
.pmin-row:hover .pmin-row__num { color: var(--red-bright); }
.pmin-row__main { min-width: 0; }
.pmin-row__title {
  font-family: var(--font-display);
  font-size: clamp(28px, 3.6vw, 42px);
  line-height: 1;
  letter-spacing: 0.018em;
  color: var(--white);
  margin-bottom: 5px;
  transition: color 0.3s var(--ease);
}
.pmin-row:hover .pmin-row__title { color: var(--red-bright); }
.pmin-row__sub {
  font-family: var(--font-accent);
  font-style: italic;
  font-size: clamp(15px, 1.45vw, 17px);
  color: var(--gray-mid);
  letter-spacing: 0.01em;
  line-height: 1.4;
  padding-left: 96px;
  max-width: 100%;
  text-wrap: balance;
}

/* Price column with embedded "Most Booked" badge */
.pmin-row__price {
  text-align: right;
  flex-shrink: 0;
  position: relative;
}
.pmin-popular {
  position: absolute;
  bottom: calc(100% + 8px);
  right: 0;
  font-family: var(--font-condensed);
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.26em;
  text-transform: uppercase;
  color: var(--gold);
  padding: 3px 8px;
  border: 1px solid rgba(201,168,76,0.32);
  background: rgba(201,168,76,0.06);
  border-radius: 1px;
  pointer-events: none;
  white-space: nowrap;
}
.pmin-row__from {
  font-family: var(--font-condensed);
  font-weight: 500;
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gray-mid);
  display: block;
  margin-bottom: 3px;
}
.pmin-row__amount {
  font-family: var(--font-display);
  font-size: clamp(30px, 4vw, 44px);
  line-height: 1;
  letter-spacing: 0.012em;
  color: var(--white);
}

.pmin-row__arrow {
  width: 34px; height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--divider-strong);
  border-radius: 50%;
  color: var(--gray-mid);
  transition: transform 0.4s var(--ease-out), border-color 0.3s var(--ease), background 0.3s var(--ease), color 0.3s var(--ease);
  flex-shrink: 0;
}
.pmin-row__arrow svg { width: 13px; height: 13px; transition: transform 0.4s var(--ease-out); }
.pmin-row:hover .pmin-row__arrow {
  border-color: var(--red);
  background: var(--red);
  color: var(--white);
  transform: rotate(-45deg);
}

/* Footnote */
.pmin-foot {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 14px;
  font-size: 13px;
  color: var(--gray-mid);
  line-height: 1.55;
  letter-spacing: 0.01em;
  padding: 0 clamp(8px, 2vw, 20px);
}
.pmin-foot__left { font-style: italic; flex: 1; min-width: 240px; }
.pmin-foot__right {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-condensed);
  font-style: normal;
  font-weight: 600;
  font-size: 11.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--red-bright);
}
.pmin-foot__right svg {
  width: 12px; height: 12px;
  animation: pmin-tap-pulse 2.4s ease-in-out infinite;
}
@keyframes pmin-tap-pulse {
  0%, 100% { transform: translateY(0); opacity: 1; }
  50%      { transform: translateY(-3px); opacity: 0.6; }
}

/* CTA strip */
.pmin-cta-strip {
  margin-top: clamp(48px, 6vw, 72px);
  padding-top: clamp(36px, 5vw, 52px);
  border-top: 1px solid var(--divider);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  flex-wrap: wrap;
}
.pmin-trust {
  display: flex;
  align-items: center;
  gap: 32px;
  flex-wrap: wrap;
}
.pmin-trust__item { display: flex; flex-direction: column; }
.pmin-trust__num {
  font-family: var(--font-display);
  font-size: 30px;
  line-height: 1;
  color: var(--white);
  letter-spacing: 0.012em;
}
.pmin-trust__num em { font-style: normal; color: var(--red); }
.pmin-trust__label {
  font-family: var(--font-condensed);
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gray-mid);
  margin-top: 6px;
}

/* ════════════════════════════════════════════════
   PRICING MODAL — calculator
═══════════════════════════════════════════════ */
.pmin-modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.84);
  z-index: 9000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.22s var(--ease);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}
.pmin-modal-overlay.open { opacity: 1; pointer-events: all; }

.pmin-modal-card {
  background: #0e0c0c;
  border: 1px solid rgba(193,39,45,0.38);
  border-radius: 3px;
  width: 100%;
  max-width: 480px;
  position: relative;
  transform: translateY(16px) scale(0.97);
  transition: transform 0.28s var(--ease-out);
  overflow: hidden;
  max-height: 92vh;
  overflow-y: auto;
  overscroll-behavior: contain;
}
.pmin-modal-overlay.open .pmin-modal-card {
  transform: translateY(0) scale(1);
}
.pmin-modal-card::before {
  content: ''; display: block;
  height: 3px;
  background: linear-gradient(to right, var(--red), var(--red-bright));
}

.pmin-modal-header {
  padding: 22px 24px 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}
.pmin-modal-trip-label {
  font-family: var(--font-condensed);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: var(--red-bright);
  text-transform: uppercase;
  margin-bottom: 5px;
}
.pmin-modal-trip-name {
  font-family: var(--font-display);
  font-size: 34px;
  line-height: 1;
  color: var(--white);
}
.pmin-modal-trip-sub {
  font-family: var(--font-accent);
  font-style: italic;
  font-size: 17px;
  color: var(--gray-light);
  margin-top: 7px;
  line-height: 1.35;
  letter-spacing: 0.005em;
}
.pmin-modal-close {
  width: 32px; height: 32px;
  border: 1px solid var(--w-14);
  border-radius: 50%;
  background: transparent;
  color: var(--gray-mid);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.18s var(--ease);
}
.pmin-modal-close:hover { border-color: var(--red); color: var(--white); }
.pmin-modal-close svg { width: 14px; height: 14px; }

.pmin-modal-divider {
  height: 1px;
  background: var(--divider);
  margin: 18px 24px;
}

.pmin-section-label {
  font-family: var(--font-condensed);
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: var(--gray-mid);
  text-transform: uppercase;
  padding: 0 24px;
  margin-bottom: 10px;
}

.pmin-toggle-row {
  display: flex;
  gap: 6px;
  padding: 0 24px 18px;
}
.pmin-toggle-pill {
  flex: 1;
  padding: 10px 4px;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--w-14);
  border-radius: 2px;
  color: var(--gray-light);
  font-family: var(--font-condensed);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: all 0.18s var(--ease);
  text-align: center;
  text-transform: uppercase;
  white-space: nowrap;
}
.pmin-toggle-pill:hover {
  border-color: rgba(193,39,45,0.5);
  color: var(--white);
  background: rgba(193,39,45,0.08);
}
.pmin-toggle-pill.active {
  border-color: var(--red);
  background: rgba(193,39,45,0.18);
  color: var(--white);
}

.pmin-group-btn {
  flex: 1;
  padding: 11px 4px;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--w-14);
  border-radius: 2px;
  color: var(--gray-light);
  font-family: var(--font-condensed);
  font-size: 17px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.15s var(--ease);
  text-align: center;
}
.pmin-group-btn:hover {
  border-color: rgba(193,39,45,0.5);
  color: var(--white);
  background: rgba(193,39,45,0.08);
}
.pmin-group-btn.active {
  border-color: var(--red);
  background: rgba(193,39,45,0.18);
  color: var(--white);
}

.pmin-price-block {
  margin: 6px 24px 0;
  background: rgba(193,39,45,0.07);
  border: 1px solid rgba(193,39,45,0.22);
  border-radius: 2px;
  padding: 18px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.pmin-price-eyebrow {
  font-family: var(--font-condensed);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: var(--gray-mid);
  text-transform: uppercase;
  margin-bottom: 4px;
}
.pmin-price-amount {
  font-family: var(--font-display);
  font-size: 54px;
  line-height: 1;
  color: var(--white);
  transition: opacity 0.1s;
}
.pmin-price-math {
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  color: var(--gray-light);
  margin-top: 8px;
  letter-spacing: 0.015em;
  font-variant-numeric: tabular-nums;
  line-height: 1.4;
}
.pmin-price-math .fee {
  color: var(--gold);
  font-weight: 700;
  letter-spacing: 0.02em;
}
.pmin-price-math em {
  font-style: normal;
  color: var(--gray-mid);
  font-weight: 400;
  padding: 0 4px;
}
.pmin-price-per-person {
  font-size: 12px;
  color: var(--gray-mid);
  margin-top: 6px;
}
.pmin-price-badge-text {
  font-family: var(--font-condensed);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold);
  background: rgba(201,168,76,0.10);
  border: 1px solid rgba(201,168,76,0.28);
  border-radius: 2px;
  padding: 4px 9px;
  white-space: nowrap;
  text-align: center;
  line-height: 1.5;
}
.pmin-honest-note {
  margin: 12px 24px 0;
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 12px;
  color: var(--gray-mid);
  line-height: 1.4;
}
.pmin-honest-note svg { flex-shrink: 0; color: var(--red); margin-top: 1px; }

.pmin-modal-cta-row {
  padding: 18px 24px 24px;
  display: flex;
  gap: 14px;
}
.pmin-modal-book-btn {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 14px 20px;
  background: var(--red);
  color: var(--white);
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 13.5px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  transform: skewX(-12deg);
  position: relative;
  overflow: hidden;
  transition: background 0.25s var(--ease), transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
}
.pmin-modal-book-btn > * { display: inline-flex; align-items: center; transform: skewX(12deg); }
.pmin-modal-book-btn::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.18), transparent 60%);
  opacity: 0;
  transition: opacity 0.3s var(--ease);
}
.pmin-modal-book-btn:hover {
  background: var(--red-bright);
  transform: skewX(-12deg) translateY(-2px);
  box-shadow: 0 8px 26px var(--red-glow);
}
.pmin-modal-book-btn:hover::after { opacity: 1; }

.pmin-modal-dismiss-btn {
  padding: 14px 22px;
  background: transparent;
  border: 1px solid var(--w-14);
  color: var(--gray-mid);
  font-family: var(--font-body);
  font-size: 13px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 500;
  cursor: pointer;
  transform: skewX(-12deg);
  transition: all 0.2s var(--ease);
}
.pmin-modal-dismiss-btn > * { display: inline-block; transform: skewX(12deg); }
.pmin-modal-dismiss-btn:hover {
  border-color: rgba(255,255,255,0.36);
  color: var(--white);
}

/* Pricing — mobile */
@media (max-width: 720px) {
  .pmin-row {
    grid-template-columns: auto 1fr auto;
    gap: 14px 18px;
    padding: clamp(24px, 3.4vw, 30px) clamp(8px, 2vw, 14px) clamp(20px, 3vw, 24px);
  }
  .pmin-row__arrow { display: none; }
  .pmin-row__num { min-width: auto; font-size: 10px; }
  .pmin-row__sub { padding-left: 0; font-size: 14px; }
  .pmin-popular { font-size: 8.5px; letter-spacing: 0.22em; padding: 2px 6px; }
  .pmin-cta-strip { flex-direction: column; align-items: flex-start; gap: 24px; }
  .pmin-cta-strip .bx-btn { align-self: stretch; justify-content: center; }
}
@media (max-width: 500px) {
  .pmin-row { grid-template-columns: 1fr auto; }
  .pmin-row__num { display: none; }
  .pmin-row__title { font-size: 26px; }
  .pmin-row__amount { font-size: 30px; }
  .pmin-row__sub { font-size: 13.5px; }
  .pmin-price-amount { font-size: 46px; }
  .pmin-modal-cta-row { flex-direction: column; }
  .pmin-toggle-row { gap: 4px; }
  .pmin-toggle-pill { font-size: 11.5px; padding: 9px 2px; letter-spacing: 0.04em; }
}

/* ════════════════════════════════════════════════════════════════
   SECTION 6 — GALLERY (12 vertical webp catches)
══════════════════════════════════════════════════════════════════ */
.gallery {
  padding: var(--section-pad-y) 0 calc(var(--section-pad-y) * 0.7);
  background: var(--black);
  position: relative;
}
.gallery::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 70% 40% at 50% 0%, rgba(193,39,45,0.05) 0%, transparent 70%);
  pointer-events: none;
}
.gallery__header {
  text-align: center;
  padding: 0 clamp(20px, 5vw, 80px);
  margin-bottom: clamp(32px, 4vw, 48px);
}
.gallery__title {
  font-family: var(--font-display);
  font-size: clamp(36px, 5vw, 58px);
  line-height: 1;
  letter-spacing: 0.012em;
  text-transform: uppercase;
  color: var(--warm-white);
  margin-top: 16px;
  margin-bottom: 14px;
}
.gallery__title .accent { color: var(--red-bright); }
.gallery__sub {
  font-family: var(--font-accent);
  font-style: italic;
  font-size: clamp(15px, 1.6vw, 18px);
  color: var(--light-slate);
  line-height: 1.6;
  max-width: 580px;
  margin: 0 auto;
}

.gallery__hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: clamp(20px, 2.5vw, 32px);
  font-family: var(--font-condensed);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--light-slate);
  opacity: 0;
  animation: gal-hint 0.6s ease 0.9s forwards;
}
@keyframes gal-hint { to { opacity: 1; } }
.gallery__arrows { display: flex; gap: 5px; align-items: center; }
.gallery__arrows i {
  display: block;
  width: 6px; height: 6px;
  border-right: 1.5px solid var(--red-bright);
  border-top: 1.5px solid var(--red-bright);
  transform: rotate(45deg);
  animation: gal-pulse-arrow 1.6s ease-in-out infinite;
}
.gallery__arrows i:nth-child(1) { animation-delay: 0s; }
.gallery__arrows i:nth-child(2) { animation-delay: 0.15s; }
.gallery__arrows i:nth-child(3) { animation-delay: 0.30s; }
@keyframes gal-pulse-arrow {
  0%, 100% { opacity: 0.15; transform: rotate(45deg) translateX(-2px); }
  50%      { opacity: 1;    transform: rotate(45deg) translateX(2px); }
}

.gallery__track-outer { position: relative; }
.gallery__track-outer::before,
.gallery__track-outer::after {
  content: '';
  position: absolute; top: 0; bottom: 0;
  width: clamp(32px, 5vw, 80px);
  z-index: 10; pointer-events: none;
}
.gallery__track-outer::before {
  left: 0;
  background: linear-gradient(to right, var(--black) 0%, transparent 100%);
}
.gallery__track-outer::after {
  right: 0;
  background: linear-gradient(to left, rgba(8,8,10,0.93) 15%, transparent 100%);
}

.gallery__track {
  --photo-ratio: 952 / 1288;
  --card-w: clamp(220px, 28vw, 310px);
  --gap: 10px;
  display: flex;
  gap: var(--gap);
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  padding: 4px clamp(24px, 6vw, 90px);
  cursor: grab;
  scrollbar-width: none;
  align-items: flex-start;
}
.gallery__track::-webkit-scrollbar { display: none; }
.gallery__track:active { cursor: grabbing; }

.gallery__card {
  flex: 0 0 var(--card-w);
  width: var(--card-w);
  aspect-ratio: var(--photo-ratio);
  scroll-snap-align: start;
  overflow: hidden;
  position: relative;
  border: 1px solid var(--w-06);
  cursor: pointer;
  transition: border-color 0.3s var(--ease);
  background: #111114;
}
.gallery__card:hover { border-color: rgba(193,39,45,0.4); }
.gallery__card img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center center;
  transition: transform 0.6s var(--ease), filter 0.4s var(--ease);
  filter: brightness(0.92) saturate(1.05);
}
.gallery__card:hover img {
  transform: scale(1.04);
  filter: brightness(1) saturate(1.12);
}
.gallery__card::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, transparent 60%, rgba(8,8,10,0.5) 100%);
  pointer-events: none;
}
.gallery__card-bar {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 3px; background: var(--red);
  transform: scaleX(0); transform-origin: left;
  transition: transform 0.4s var(--ease);
  z-index: 2;
}
.gallery__card:hover .gallery__card-bar { transform: scaleX(1); }
.gallery__card-zoom {
  position: absolute; top: 12px; right: 12px;
  width: 30px; height: 30px;
  background: rgba(8,8,10,0.65);
  border: 1px solid rgba(240,236,228,0.18);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transform: scale(0.75);
  transition: opacity 0.3s, transform 0.3s;
  z-index: 3;
  backdrop-filter: blur(4px);
}
.gallery__card:hover .gallery__card-zoom { opacity: 1; transform: scale(1); }
.gallery__card-zoom svg { stroke: var(--cream); }

@media (max-width: 600px) {
  .gallery__track { --card-w: 72vw; }
}

/* Gallery nav strip */
.gallery__nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: clamp(16px, 3vw, 32px);
  margin-top: clamp(24px, 3vw, 40px);
  padding: 0 clamp(20px, 5vw, 80px);
}
.gallery__nav-btn {
  width: 48px; height: 48px;
  border: 1px solid rgba(240,236,228,0.15);
  background: transparent;
  color: var(--cream);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s var(--ease);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}
.gallery__nav-btn::before {
  content: '';
  position: absolute; inset: 0;
  background: var(--red);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s var(--ease);
}
.gallery__nav-btn:hover { border-color: var(--red); }
.gallery__nav-btn:hover::before { transform: scaleX(1); }
.gallery__nav-btn svg { position: relative; z-index: 1; }
.gallery__nav-btn:disabled { opacity: 0.22; cursor: not-allowed; }
.gallery__nav-btn:disabled:hover { border-color: rgba(240,236,228,0.15); }
.gallery__nav-btn:disabled:hover::before { transform: scaleX(0); }

.gallery__progress { flex: 1; max-width: 340px; }
.gallery__progress-track {
  height: 1px; background: rgba(240,236,228,0.1);
  position: relative; overflow: hidden;
}
.gallery__progress-fill {
  position: absolute; left: 0; top: 0; bottom: 0;
  background: var(--red);
  transition: width 0.4s var(--ease);
  width: 8%;
}
.gallery__counter {
  text-align: center;
  margin-top: 10px;
  font-family: var(--font-condensed);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--light-slate);
}
.gallery__counter strong { color: var(--cream); font-weight: 600; }

/* Lightbox */
.lightbox {
  position: fixed; inset: 0;
  background: rgba(8,8,10,0.97);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.35s var(--ease);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.lightbox.open { opacity: 1; pointer-events: all; }
.lightbox__inner {
  position: relative;
  max-height: 92vh;
  max-width: min(92vw, 540px);
  width: auto;
}
.lightbox__inner img {
  display: block;
  max-height: 90vh;
  max-width: 100%;
  width: auto; height: auto;
  object-fit: contain;
  border: 1px solid rgba(255,255,255,0.06);
}
.lightbox__close {
  position: absolute; top: -42px; right: 0;
  background: none; border: none;
  color: var(--cream);
  font-size: 28px;
  cursor: pointer;
  line-height: 1;
  opacity: 0.6;
  transition: opacity 0.2s, color 0.2s;
}
.lightbox__close:hover { opacity: 1; color: var(--red-bright); }
.lightbox__nav {
  position: absolute; top: 50%; transform: translateY(-50%);
  background: rgba(8,8,10,0.6);
  border: 1px solid rgba(240,236,228,0.15);
  color: var(--cream);
  cursor: pointer;
  width: 40px; height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, border-color 0.2s;
  backdrop-filter: blur(4px);
}
.lightbox__nav:hover { background: var(--red); border-color: var(--red); }
.lightbox__nav--prev { left: -56px; }
.lightbox__nav--next { right: -56px; }
@media (max-width: 700px) {
  .lightbox__nav--prev { left: 8px; }
  .lightbox__nav--next { right: 8px; }
}

/* ════════════════════════════════════════════════════════════════
   SECTION 7 — TESTIMONIALS (3-card grid)
══════════════════════════════════════════════════════════════════ */
.testimonials { background: var(--charcoal); }
.testimonials__header {
  text-align: center;
  margin-bottom: clamp(50px, 6vw, 80px);
}
.testimonials__rating {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 18px;
}
.testimonials__stars {
  color: var(--gold);
  font-size: 22px;
  letter-spacing: 0.18em;
}
.testimonials__count {
  font-size: 14px;
  color: var(--slate);
  font-weight: 400;
}
.testimonials__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.test-card {
  padding: clamp(28px, 3vw, 44px);
  background: var(--dark);
  border: 1px solid var(--w-06);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  transition: border-color 0.3s var(--ease), background 0.3s var(--ease);
}
.test-card:hover {
  border-color: rgba(193,39,45,0.22);
  background: var(--mid-dark);
}
.test-card__stars {
  color: var(--gold);
  font-size: 14px;
  letter-spacing: 0.12em;
  margin-bottom: 22px;
}
.test-card__quote {
  font-family: var(--font-accent);
  font-style: italic;
  font-size: clamp(17px, 1.6vw, 20px);
  line-height: 1.65;
  color: var(--cream);
  margin-bottom: 28px;
  flex-grow: 1;
}
.test-card__author {
  font-size: 13px;
  font-weight: 600;
  color: var(--warm-white);
  letter-spacing: 0.01em;
}
.test-card__location {
  font-size: 12px;
  color: var(--slate);
  font-weight: 400;
  margin-top: 2px;
}
.test-card__trip {
  font-family: var(--font-condensed);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--red);
  margin-top: 8px;
}
@media (max-width: 1024px) {
  .testimonials__grid { grid-template-columns: 1fr; }
}

/* ════════════════════════════════════════════════════════════════
   SECTION 8 — SEASONAL CTA ("Know When to Book")
══════════════════════════════════════════════════════════════════ */
.cta {
  position: relative;
  background: var(--charcoal);
  overflow: hidden;
}
.cta__inner {
  position: relative;
  text-align: center;
  z-index: 2;
}
.cta__bg-text {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-family: var(--font-display);
  font-size: clamp(100px, 18vw, 280px);
  text-transform: uppercase;
  color: rgba(240,236,228,0.022);
  white-space: nowrap;
  pointer-events: none;
  z-index: 0;
  letter-spacing: 0.05em;
  line-height: 1;
}
.cta__title {
  font-family: var(--font-display);
  font-size: clamp(40px, 6vw, 72px);
  line-height: 1;
  letter-spacing: 0.012em;
  text-transform: uppercase;
  color: var(--warm-white);
  margin-bottom: 22px;
}
.cta__title .accent { color: var(--red-bright); }
.cta__sub {
  font-family: var(--font-accent);
  font-size: clamp(18px, 2vw, 22px);
  font-style: italic;
  color: var(--light-slate);
  max-width: 580px;
  margin: 0 auto 40px;
  line-height: 1.6;
}
.cta__actions {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}
.cta__note {
  margin-top: 24px;
  font-size: 13px;
  color: var(--slate);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.cta__note svg { fill: #22c55e; flex-shrink: 0; }

/* ════════════════════════════════════════════════════════════════
   SECTION 9 — FOOTER
══════════════════════════════════════════════════════════════════ */
.footer {
  position: relative;
  width: 100%;
  background: var(--black);
  color: var(--cream);
  padding: 78px clamp(20px, 4vw, 48px) 30px;
  border-top: 1px solid var(--w-06);
}
.footer__inner {
  max-width: 1280px;
  margin: 0 auto;
}
.footer__grid {
  display: grid;
  grid-template-columns: 1.35fr 1fr 1fr 1fr;
  gap: 64px;
  padding-bottom: 58px;
}
.footer__brand-name {
  font-family: var(--font-display);
  font-size: 32px;
  letter-spacing: 0.045em;
  color: var(--white);
  line-height: 1;
  margin-bottom: 20px;
}
.footer__tagline {
  font-size: 14.5px;
  font-weight: 400;
  color: var(--gray-mid);
  line-height: 1.75;
  max-width: 360px;
  margin-bottom: 32px;
}
.footer__socials {
  display: flex;
  gap: 12px;
}
.footer__social {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.22);
  color: var(--gray-light);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.02em;
  transition: all 0.2s var(--ease);
}
.footer__social:hover,
.footer__social:focus-visible {
  background: var(--red);
  border-color: var(--red);
  color: var(--white);
  transform: translateY(-2px);
  outline: none;
}
.footer__col-title {
  font-family: var(--font-condensed);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.32em;
  color: var(--white);
  text-transform: uppercase;
  margin-bottom: 26px;
}
.footer__links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.footer__links a,
.footer__links .footer__static {
  color: var(--gray-light);
  font-size: 14.5px;
  font-weight: 400;
  line-height: 1.35;
  transition: color 0.15s var(--ease);
  display: inline-block;
}
.footer__links a:hover,
.footer__links a:focus-visible {
  color: var(--red-bright);
  outline: none;
}
.footer__divider {
  height: 1px;
  background: var(--divider);
  margin-bottom: 22px;
}
.footer__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 12.5px;
  color: var(--gray-mid);
  letter-spacing: 0.02em;
}
