  (function initPricingModal(){
    var modal     = document.getElementById('pminModal');
    var modalCard = modal ? modal.querySelector('.pmin-modal-card') : null;
    if (!modal || !modalCard) return;

    var rows       = document.querySelectorAll('.pmin-row');
    var closeBtns  = [document.getElementById('pminModalClose'), document.getElementById('pminDismissBtn')];
    var nameEl     = document.getElementById('pminModalName');
    var subEl      = document.getElementById('pminModalSub');
    var amountEl   = document.getElementById('pminPriceAmount');
    var mathEl     = document.getElementById('pminPriceMath');
    var perEl      = document.getElementById('pminPerPerson');
    var bookBtn    = document.getElementById('pminBookBtn');
    var seasonRow  = document.getElementById('pminSeasonRow');
    var groupRow   = document.getElementById('pminGroupRow');

    // Trip data — net base prices and per-guest add-ons (from Pricing Engine v2)
    var TRIPS = {
      4: { name: '4 Hour Trip',  base: 425, sub: 'Half-day on the water — perfect for an early bite or evening run.',     perAddOn: [50, 50, 100] },
      5: { name: '5 Hour Trip',  base: 550, sub: 'The sweet spot — extra time without making it a full-day commitment.',  perAddOn: [62.5, 62.5, 100] },
      6: { name: '6 Hour Trip',  base: 700, sub: 'Built for serious anglers — patterns, structure, and multiple species.', perAddOn: [75, 75, 125] },
      8: { name: '8 Hour Trip',  base: 950, sub: 'Sun-up to mid-afternoon. Big-water exploration, lunch on the boat.',    perAddOn: [100, 100, 175] }
    };
    // perAddOn array = [3rd guest, 4th guest, 5th guest] additions

    var state = { trip: 4, seasonMult: 1.00, groupSize: 2 };
    var FEE = 0.06;

    function fmt(n){ return '$' + Math.round(n).toLocaleString(); }
    function fmtFee(n){ return '$' + n.toFixed(2).replace(/\.00$/, ''); }

    function calculate(){
      var trip = TRIPS[state.trip];
      if (!trip) return;
      var net = trip.base * state.seasonMult;
      var addOns = 0;
      for (var i = 3; i <= state.groupSize; i++) {
        addOns += trip.perAddOn[i - 3];
      }
      net += addOns;
      var fee = net * FEE;
      var total = net + fee;

      amountEl.style.opacity = '0';
      requestAnimationFrame(function(){
        amountEl.textContent = fmt(total);
        mathEl.innerHTML = fmt(net) + ' <em>+</em> <span class="fee">' + fmtFee(fee) + ' Provider Fee (6%)</span> <em>=</em> ' + fmt(total);
        perEl.textContent = state.groupSize === 2 ? 'For 1–2 guests' : 'For ' + state.groupSize + ' guests';
        amountEl.style.opacity = '1';
      });
    }

    function openModal(tripLen){
      state.trip = tripLen;
      var trip = TRIPS[tripLen];
      nameEl.textContent = trip.name;
      subEl.textContent = trip.sub;
      calculate();
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeModal(){
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }

    rows.forEach(function(row){
      row.addEventListener('click', function(){
        var t = parseInt(row.dataset.trip, 10);
        if (TRIPS[t]) openModal(t);
      });
    });

    closeBtns.forEach(function(btn){
      if (btn) btn.addEventListener('click', closeModal);
    });

    modal.addEventListener('click', function(e){
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', function(e){
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });

    seasonRow.addEventListener('click', function(e){
      var btn = e.target.closest('.pmin-toggle-pill');
      if (!btn) return;
      seasonRow.querySelectorAll('.pmin-toggle-pill').forEach(function(p){
        p.classList.remove('active');
        p.setAttribute('aria-checked', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-checked', 'true');
      state.seasonMult = parseFloat(btn.dataset.mult);
      calculate();
    });

    groupRow.addEventListener('click', function(e){
      var btn = e.target.closest('.pmin-group-btn');
      if (!btn) return;
      groupRow.querySelectorAll('.pmin-group-btn').forEach(function(p){
        p.classList.remove('active');
        p.setAttribute('aria-checked', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-checked', 'true');
      state.groupSize = parseInt(btn.dataset.group, 10);
      calculate();
    });
  })();


  /* ═══════════════════════════════════════════════════════════
     SCROLL REVEAL — single observer for the entire page
     Stagger via per-element transitionDelay (NOT setTimeout).
     classList.add wrapped in rAF.
  ═══════════════════════════════════════════════════════════ */
  (function initReveal(){
    var reveals = document.querySelectorAll('.reveal');
    if (!reveals.length) return;

    // Stamp staggered delay per element at init
    reveals.forEach(function(el, i){
      el.style.transitionDelay = (i * 60) + 'ms';
    });

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      reveals.forEach(function(el){
        el.style.transitionDelay = '0ms';
        el.classList.add('visible');
      });
      return;
    }

    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (entry.isIntersecting) {
          requestAnimationFrame(function(){
            entry.target.classList.add('visible');
          });
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    reveals.forEach(function(el){ io.observe(el); });
  })();


  /* ═══════════════════════════════════════════════════════════
     IFRAME HEIGHT REPORTER — fixes Wix Custom Embed scroll
  ═══════════════════════════════════════════════════════════ */
  (function initHeightReporter(){
    if (window.parent === window) return;
    var lastH = 0;
    function report(){
      var h = Math.max(
        document.documentElement.scrollHeight,
        document.body ? document.body.scrollHeight : 0
      );
      if (h && h !== lastH) {
        lastH = h;
        try { window.parent.postMessage({ type: 'setHeight', height: h }, '*'); } catch (e) {}
        try { window.parent.postMessage({ type: 'embed-size', height: h }, '*'); } catch (e) {}
        try { window.parent.postMessage('height:' + h, '*'); } catch (e) {}
      }
    }
    window.addEventListener('load', report);
    window.addEventListener('resize', report);
    if (window.ResizeObserver) {
      try { new ResizeObserver(report).observe(document.body); } catch (e) {}
    }
    setInterval(report, 1500);
  })();

})();
</script>

